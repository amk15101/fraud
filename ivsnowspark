def _merge_for_monotonicity(bin_stats, bins, max_bins, min_pct, total_records):
    """
    Merge adjacent bins to enforce monotonicity of event rates.
    Uses difference in event rates to decide which adjacent bins to merge first.
    """

    
    current_bins = list(bins)
    
    while True:
        # Recalculate stats with current bins
        n_bins = len(current_bins) - 1
        
        if n_bins <= 2:
            break
        
        # Check monotonicity
        event_rates = []
        for i in range(n_bins):
            lower = current_bins[i]
            upper = current_bins[i + 1]
            mask = (bin_stats['bin'] >= i)  # simplified
            event_rates.append(bin_stats.iloc[i]['event_rate'] if i < len(bin_stats) else 0)
        
        # Check if monotonically increasing or decreasing
        is_increasing = all(event_rates[i] <= event_rates[i+1] for i in range(len(event_rates)-1))
        is_decreasing = all(event_rates[i] >= event_rates[i+1] for i in range(len(event_rates)-1))
        
        if is_increasing or is_decreasing:
            break
        
        # Find the pair with minimum chi-square and merge
        min_chi2 = np.inf
        merge_idx = 0
        
        for i in range(len(event_rates) - 1):
            # Simple difference as proxy for chi-square
            chi2 = abs(event_rates[i] - event_rates[i+1])
            if chi2 < min_chi2:
                min_chi2 = chi2
                merge_idx = i
        
        # Merge bins at merge_idx and merge_idx + 1
        current_bins.pop(merge_idx + 1)
        
        if len(current_bins) <= 2:
            break
    
    # Also enforce max_bins
    while len(current_bins) - 1 > max_bins:
        # Merge the pair with smallest chi-square difference
        min_diff = np.inf
        merge_idx = 0
        for i in range(len(current_bins) - 2):
            diff = current_bins[i+2] - current_bins[i+1] if current_bins[i+2] != np.inf and current_bins[i+1] != -np.inf else np.inf
            if diff < min_diff:
                min_diff = diff
                merge_idx = i
        current_bins.pop(merge_idx + 1)
    
    return np.array(current_bins)


def _monotonic_binning(data, col, target_col, max_bins, min_pct):
    """Create monotonic bins by starting with fine bins and merging."""
    try:
        total_records = len(data)
        n_initial = min(50, data[col].nunique())
        
        if n_initial <= 2:
            return None
            
        _, bins = pd.qcut(data[col], q=n_initial, duplicates='drop', retbins=True)
        
        if len(bins) <= 2:
            return None
        
        bins[0] = -np.inf
        bins[-1] = np.inf
        
        # Assign bins
        data_copy = data.copy()
        data_copy['bin'] = pd.cut(data_copy[col], bins=bins, labels=False, include_lowest=True)
        
        # Calculate event rate per bin
        bin_stats = data_copy.groupby('bin').agg(
            count=(target_col, 'count'),
            events=(target_col, 'sum')
        ).reset_index()
        bin_stats['event_rate'] = bin_stats['events'] / bin_stats['count']
        
        # Merge bins to enforce monotonicity
        merged_bins = _merge_for_monotonicity(bin_stats, bins, max_bins, min_pct, total_records)
        
        return merged_bins
    except Exception:
        return None


def _compute_woe_for_bins(data, col, target_col, bins, total_events, 
                          total_non_events, missing_mask):
    """Compute WOE and IV for given bins."""
    
    data_copy = data.copy()
    
    # Assign bins for non-missing values
    non_missing_data = data_copy[~missing_mask].copy()
    
    try:
        non_missing_data['bin'] = pd.cut(non_missing_data[col], bins=bins, 
                                          include_lowest=True, duplicates='drop')
    except Exception:
        return None, None, None
    
    # Group by bin
    grouped = non_missing_data.groupby('bin', observed=True).agg(
        count=(target_col, 'count'),
        events=(target_col, 'sum')
    ).reset_index()
    
    grouped['non_events'] = grouped['count'] - grouped['events']
    
    # Remove empty bins
    grouped = grouped[grouped['count'] > 0].reset_index(drop=True)
    
    if len(grouped) == 0:
        return None, None, None
    
    # Calculate distribution of events and non-events
    grouped['pct_events'] = grouped['events'] / total_events
    grouped['pct_non_events'] = grouped['non_events'] / total_non_events
    
    # Apply smoothing to avoid division by zero or log(0)
    epsilon = 0.5
    grouped['pct_events_adj'] = np.where(
        grouped['pct_events'] == 0, 
        epsilon / total_events, 
        grouped['pct_events']
    )
    grouped['pct_non_events_adj'] = np.where(
        grouped['pct_non_events'] == 0, 
        epsilon / total_non_events, 
        grouped['pct_non_events']
    )
    
    # Calculate WOE
    grouped['woe'] = np.log(grouped['pct_non_events_adj'] / grouped['pct_events_adj'])
    
    # Calculate IV contribution
    grouped['iv'] = (grouped['pct_non_events_adj'] - grouped['pct_events_adj']) * grouped['woe']
    
    # Handle missing values bin
    missing_data = data_copy[missing_mask]
    if len(missing_data) > 0:
        missing_events = missing_data[target_col].sum()
        missing_non_events = len(missing_data) - missing_events
        
        pct_events_missing = max(missing_events / total_events, epsilon / total_events)
        pct_non_events_missing = max(missing_non_events / total_non_events, epsilon / total_non_events)
        
        woe_missing = np.log(pct_non_events_missing / pct_events_missing)
        iv_missing = (pct_non_events_missing - pct_events_missing) * woe_missing
        
        missing_row = pd.DataFrame({
            'bin': ['Missing'],
            'count': [len(missing_data)],
            'events': [missing_events],
            'non_events': [missing_non_events],
            'pct_events': [missing_events / total_events],
            'pct_non_events': [missing_non_events / total_non_events],
            'pct_events_adj': [pct_events_missing],
            'pct_non_events_adj': [pct_non_events_missing],
            'woe': [woe_missing],
            'iv': [iv_missing]
        })
        
        grouped = pd.concat([grouped, missing_row], ignore_index=True)
    
    # Total IV
    total_iv = grouped['iv'].sum()
    
    # Handle infinite IV
    if np.isinf(total_iv) or np.isnan(total_iv):
        return None, None, None
    
    # Create mapping for transformation
    mapping = {
        'bins': bins,
        'woe_values': grouped[grouped['bin'] != 'Missing']['woe'].values,
        'bin_labels': grouped[grouped['bin'] != 'Missing']['bin'].values,
        'missing_woe': grouped[grouped['bin'] == 'Missing']['woe'].values[0] if len(missing_data) > 0 else 0
    }
    
    # Clean up output
    woe_df = grouped[['bin', 'count', 'events', 'non_events', 'pct_events', 
                       'pct_non_events', 'woe', 'iv']].copy()
    woe_df['event_rate'] = woe_df['events'] / woe_df['count']
    woe_df['pct_total'] = woe_df['count'] / len(data_copy)
    
    return woe_df, total_iv, mapping


def _calculate_woe_categorical(pdf, col, target_col, total_events, total_non_events):
    """Calculate WOE and IV for categorical variables."""
    
    data = pdf[[col, target_col]].copy()
    
    # Handle missing values
    data[col] = data[col].fillna('__MISSING__')
    
    # Group by category
    grouped = data.groupby(col).agg(
        count=(target_col, 'count'),
        events=(target_col, 'sum')
    ).reset_index()
    
    grouped['non_events'] = grouped['count'] - grouped['events']
    
    # Remove categories with zero count
    grouped = grouped[grouped['count'] > 0].reset_index(drop=True)
    
    if len(grouped) == 0:
        return None, None, None
    
    # Calculate distributions
    grouped['pct_events'] = grouped['events'] / total_events
    grouped['pct_non_events'] = grouped['non_events'] / total_non_events
    
    # Apply smoothing
    epsilon = 0.5
    grouped['pct_events_adj'] = np.where(
        grouped['pct_events'] == 0,
        epsilon / total_events,
        grouped['pct_events']
    )
    grouped['pct_non_events_adj'] = np.where(
        grouped['pct_non_events'] == 0,
        epsilon / total_non_events,
        grouped['pct_non_events']
    )
    
    # Calculate WOE
    grouped['woe'] = np.log(grouped['pct_non_events_adj'] / grouped['pct_events_adj'])
    
    # Calculate IV
    grouped['iv'] = (grouped['pct_non_events_adj'] - grouped['pct_events_adj']) * grouped['woe']
    
    # Total IV
    total_iv = grouped['iv'].sum()
    
    if np.isinf(total_iv) or np.isnan(total_iv):
        return None, None, None
    
    # Create mapping
    mapping = dict(zip(grouped[col], grouped['woe']))
    
    # Clean output
    grouped = grouped.rename(columns={col: 'bin'})
    woe_df = grouped[['bin', 'count', 'events', 'non_events', 'pct_events',
                       'pct_non_events', 'woe', 'iv']].copy()
    woe_df['event_rate'] = woe_df['events'] / woe_df['count']
    woe_df['pct_total'] = woe_df['count'] / len(pdf)
    
    return woe_df, total_iv, mapping


def _apply_numeric_woe(series, mapping):
    """Apply WOE mapping to a numeric series."""
    bins = mapping['bins']
    woe_values = mapping['woe_values']
    missing_woe = mapping['missing_woe']
    
    # Create bin assignments
    try:
        bin_assignments = pd.cut(series, bins=bins, labels=False, include_lowest=True)
    except Exception:
        return pd.Series([0] * len(series))
    
    # Map bin index to WOE value
    result = pd.Series(index=series.index, dtype=float)
    
    for i, woe in enumerate(woe_values):
        result[bin_assignments == i] = woe
    
    # Handle missing values
    result[series.isnull()] = missing_woe
    
    # Fill any remaining NaN with 0
    result = result.fillna(0)
    
    return result


def _is_monotonic(woe_df):
    """Check if WOE values are monotonically increasing or decreasing."""
    # Exclude missing bin
    woe_values = woe_df[woe_df['bin'] != 'Missing']['woe'].values
    
    if len(woe_values) <= 1:
        return True
    
    # Check increasing
    is_increasing = all(woe_values[i] <= woe_values[i+1] for i in range(len(woe_values)-1))
    # Check decreasing
    is_decreasing = all(woe_values[i] >= woe_values[i+1] for i in range(len(woe_values)-1))
    
    return is_increasing or is_decreasing


def _get_predictive_power(iv_value):
    """Classify IV value into predictive power categories."""
    if iv_value < 0.02:
        return "Not Predictive"
    elif iv_value < 0.1:
        return "Weak"
    elif iv_value < 0.3:
        return "Medium"
    elif iv_value < 0.5:
        return "Strong"
    else:
        return "Suspicious (Too Good)"


