def calculate_woe_iv(sp_df, target_col, max_bins=20, min_pct=0.05, 
                     cardinality_threshold=50, date_keywords=None, 
                     id_keywords=None):
    """
    Calculate Weight of Evidence (WOE) and Information Value (IV) for all 
    eligible variables in a Snowflake Spark DataFrame.
    
    Parameters:
    -----------
    sp_df : pyspark.sql.DataFrame
        Input Spark DataFrame (from Snowflake)
    target_col : str
        Name of the binary target variable (0/1)
    max_bins : int
        Maximum number of bins for numeric variables (default: 20)
    min_pct : float
        Minimum percentage of records in each bin (default: 0.05)
    cardinality_threshold : int
        Maximum unique values allowed for categorical variables (default: 50)
    date_keywords : list
        Keywords to identify date columns by name (default: common date keywords)
    id_keywords : list
        Keywords to identify ID columns by name (default: common ID keywords)
    
    Returns:
    --------
    dict with keys:
        - 'iv_summary': DataFrame with IV values for each variable
        - 'woe_details': Dict of DataFrames with WOE details per variable
        - 'removed_columns': List of removed columns with reasons
        - 'transformed_df': Spark DataFrame with WOE-transformed variables
    """
    
    if date_keywords is None:
        date_keywords = ['date', 'dt', 'time', 'timestamp', 'created', 'updated', 
                         'modified', 'inserted', 'loaded', 'extracted', 'dob', 
                         'birth', 'start_dt', 'end_dt', 'eff_dt', 'exp_dt']
    
    if id_keywords is None:
        id_keywords = ['id', '_id', 'key', '_key', 'pk', '_pk', 'sk', '_sk',
                       'uuid', 'guid', 'identifier', 'index', 'idx', 'seq',
                       'sequence', 'number', 'num', 'no', 'code', 'ssn', 
                       'phone', 'email', 'address', 'name', 'account_no',
                       'acct_no', 'policy_no', 'claim_no']
    
    # Convert to Pandas for easier manipulation
    print("Converting Spark DataFrame to Pandas...")
    pdf = sp_df.toPandas()
    
    total_records = len(pdf)
    print(f"Total records: {total_records}")
    print(f"Total columns: {len(pdf.columns)}")
    
    # Validate target column
    if target_col not in pdf.columns:
        raise ValueError(f"Target column '{target_col}' not found in DataFrame")
    
    unique_targets = pdf[target_col].dropna().unique()
    if not set(unique_targets).issubset({0, 1}):
        raise ValueError(f"Target column must be binary (0/1). Found values: {unique_targets}")
    
    # Track removed columns
    removed_columns = []
    eligible_columns = []
    
    # Get schema info from Spark DataFrame
    schema_dict = {field.name: field.dataType for field in sp_df.schema.fields}
    
    # =========================================================================
    # STEP 1: Identify and remove date/ID/high-cardinality columns
    # =========================================================================
    print("\n" + "="*60)
    print("STEP 1: Filtering columns...")
    print("="*60)
    
    for col in pdf.columns:
        if col == target_col:
            continue
        
        remove_reason = None
        col_lower = col.lower()
        
        # Check if column is a date type by Spark schema
        spark_type = schema_dict.get(col)
        if isinstance(spark_type, (TimestampType, DateType)):
            remove_reason = f"Date/Timestamp type detected (Spark type: {spark_type})"
        
        # Check if column name matches date keywords
        if remove_reason is None:
            for keyword in date_keywords:
                if keyword.lower() in col_lower:
                    # Additional check: try to parse as date
                    if pdf[col].dtype == 'object':
                        try:
                            sample = pdf[col].dropna().head(100)
                            pd.to_datetime(sample)
                            remove_reason = f"Date column detected (keyword: '{keyword}', parseable as date)"
                            break
                        except (ValueError, TypeError):
                            pass
                    elif pd.api.types.is_datetime64_any_dtype(pdf[col]):
                        remove_reason = f"Date column detected (datetime dtype, keyword: '{keyword}')"
                        break
        
        # Check if column name matches ID keywords
        if remove_reason is None:
            for keyword in id_keywords:
                if (col_lower == keyword or 
                    col_lower.startswith(keyword + '_') or 
                    col_lower.endswith('_' + keyword) or
                    col_lower.startswith(keyword) and col_lower[len(keyword):].isdigit()):
                    
                    # Verify high cardinality for ID-like columns
                    n_unique = pdf[col].nunique()
                    cardinality_ratio = n_unique / total_records
                    
                    if cardinality_ratio > 0.5 or n_unique > cardinality_threshold * 10:
                        remove_reason = (f"ID column detected (keyword: '{keyword}', "
                                        f"unique values: {n_unique}, "
                                        f"cardinality ratio: {cardinality_ratio:.4f})")
                        break
        
        # Check high cardinality for string/categorical columns
        if remove_reason is None:
            if pdf[col].dtype == 'object' or isinstance(spark_type, StringType):
                n_unique = pdf[col].nunique()
                cardinality_ratio = n_unique / total_records
                
                if n_unique > cardinality_threshold:
                    remove_reason = (f"High cardinality categorical "
                                    f"(unique values: {n_unique}, "
                                    f"threshold: {cardinality_threshold})")
                elif cardinality_ratio > 0.9:
                    remove_reason = (f"Near-unique categorical "
                                    f"(cardinality ratio: {cardinality_ratio:.4f})")
        
        # Check if column has only one unique value
        if remove_reason is None:
            if pdf[col].nunique() <= 1:
                remove_reason = "Constant column (0 or 1 unique values)"
        
        # Check if column is all null
        if remove_reason is None:
            if pdf[col].isnull().all():
                remove_reason = "All null values"
        
        if remove_reason:
            removed_columns.append({'column': col, 'reason': remove_reason})
            print(f"  REMOVED: {col} -> {remove_reason}")
        else:
            eligible_columns.append(col)
    
    print(f"\nEligible columns for WOE/IV: {len(eligible_columns)}")
    print(f"Removed columns: {len(removed_columns)}")
    
    # =========================================================================
    # STEP 2: Calculate optimal WOE and IV for each eligible variable
    # =========================================================================
    print("\n" + "="*60)
    print("STEP 2: Calculating WOE and IV...")
    print("="*60)
    
    iv_results = {}
    woe_details = {}
    woe_mappings = {}
    
    total_events = pdf[target_col].sum()
    total_non_events = total_records - total_events
    
    if total_events == 0 or total_non_events == 0:
        raise ValueError("Target variable must have both 0 and 1 values")
    
    for col in eligible_columns:
        try:
            if pd.api.types.is_numeric_dtype(pdf[col]):
                # Numeric variable - find optimal binning
                woe_df, iv_value, mapping = _optimal_binning_numeric(
                    pdf, col, target_col, total_events, total_non_events,
                    max_bins, min_pct
                )
            else:
                # Categorical variable
                woe_df, iv_value, mapping = _calculate_woe_categorical(
                    pdf, col, target_col, total_events, total_non_events
                )
            
            if woe_df is not None and iv_value is not None:
                iv_results[col] = iv_value
                woe_details[col] = woe_df
                woe_mappings[col] = mapping
                
                # Determine predictive power
                power = _get_predictive_power(iv_value)
                print(f"  {col}: IV = {iv_value:.4f} ({power})")
            else:
                removed_columns.append({
                    'column': col, 
                    'reason': 'Could not calculate WOE (insufficient data variation)'
                })
                
        except Exception as e:
            removed_columns.append({
                'column': col, 
                'reason': f'Error during WOE calculation: {str(e)}'
            })
    
    # =========================================================================
    # STEP 3: Create IV summary
    # =========================================================================
    print("\n" + "="*60)
    print("STEP 3: IV Summary")
    print("="*60)
    
    iv_summary = pd.DataFrame({
        'variable': list(iv_results.keys()),
        'iv': list(iv_results.values())
    }).sort_values('iv', ascending=False).reset_index(drop=True)
    
    iv_summary['predictive_power'] = iv_summary['iv'].apply(_get_predictive_power)
    iv_summary['rank'] = range(1, len(iv_summary) + 1)
    
    print(iv_summary.to_string(index=False))
    
    # =========================================================================
    # STEP 4: Create WOE-transformed DataFrame
    # =========================================================================
    print("\n" + "="*60)
    print("STEP 4: Creating WOE-transformed DataFrame...")
    print("="*60)
    
    woe_transformed = pdf[[target_col]].copy()
    
    for col, mapping in woe_mappings.items():
        if pd.api.types.is_numeric_dtype(pdf[col]):
            woe_transformed[col + '_woe'] = _apply_numeric_woe(pdf[col], mapping)
        else:
            woe_transformed[col + '_woe'] = pdf[col].map(mapping).fillna(0)
    
    # Convert back to Spark DataFrame
    from pyspark.sql import SparkSession
    spark = SparkSession.builder.getOrCreate()
    transformed_sp_df = spark.createDataFrame(woe_transformed)
    
    print(f"Transformed DataFrame columns: {len(woe_transformed.columns)}")
    
    # =========================================================================
    # STEP 5: Compile results
    # =========================================================================
    removed_df = pd.DataFrame(removed_columns) if removed_columns else pd.DataFrame(
        columns=['column', 'reason'])
    
    results = {
        'iv_summary': iv_summary,
        'woe_details': woe_details,
        'removed_columns': removed_df,
        'transformed_df': transformed_sp_df,
        'woe_mappings': woe_mappings
    }
    
    print("\n" + "="*60)
    print("COMPLETE!")
    print(f"  Variables with IV calculated: {len(iv_results)}")
    print(f"  Variables removed: {len(removed_columns)}")
    print("="*60)
    
    return results


def _optimal_binning_numeric(pdf, col, target_col, total_events, total_non_events,
                             max_bins=20, min_pct=0.05):
    """
    Find optimal bins for a numeric variable using monotonic binning approach.
    Uses a combination of quantile-based initial binning and merging based on
    chi-square statistics to find optimal splits.
    """
    # Handle missing values
    data = pdf[[col, target_col]].copy()
    missing_mask = data[col].isnull()
    data_non_missing = data[~missing_mask].copy()
    
    if len(data_non_missing) == 0:
        return None, None, None
    
    n_unique = data_non_missing[col].nunique()
    
    if n_unique <= 2:
        # If very few unique values, treat as categorical
        return _calculate_woe_categorical(pdf, col, target_col, 
                                          total_events, total_non_events)
    
    # Determine initial number of bins
    initial_bins = min(max_bins, max(n_unique, 5))
    
    # Try multiple binning strategies and pick the best one
    best_iv = -1
    best_woe_df = None
    best_mapping = None
    
    # Strategy 1: Quantile-based binning with monotonic enforcement
    for n_bins in range(min(initial_bins, 20), 1, -1):
        try:
            bins = _create_quantile_bins(data_non_missing[col], n_bins, min_pct)
            if bins is None:
                continue
            
            woe_df, iv_value, mapping = _compute_woe_for_bins(
                data, col, target_col, bins, total_events, total_non_events,
                missing_mask
            )
            
            if iv_value is not None and iv_value > best_iv:
                # Check monotonicity
                if _is_monotonic(woe_df):
                    best_iv = iv_value
                    best_woe_df = woe_df
                    best_mapping = mapping
                    break
                elif iv_value > best_iv:
                    best_iv = iv_value
                    best_woe_df = woe_df
                    best_mapping = mapping
        except Exception:
            continue
    
    # Strategy 2: Decision tree-based optimal binning
    try:
        tree_bins = _tree_based_binning(data_non_missing, col, target_col, max_bins, min_pct)
        if tree_bins is not None:
            woe_df, iv_value, mapping = _compute_woe_for_bins(
                data, col, target_col, tree_bins, total_events, total_non_events,
                missing_mask
            )
            if iv_value is not None and iv_value > best_iv:
                best_iv = iv_value
                best_woe_df = woe_df
                best_mapping = mapping
    except Exception:
        pass
    
    # Strategy 3: Monotonic binning via merging
    try:
        mono_bins = _monotonic_binning(data_non_missing, col, target_col, max_bins, min_pct)
        if mono_bins is not None:
            woe_df, iv_value, mapping = _compute_woe_for_bins(
                data, col, target_col, mono_bins, total_events, total_non_events,
                missing_mask
            )
            if iv_value is not None and iv_value > best_iv:
                best_iv = iv_value
                best_woe_df = woe_df
                best_mapping = mapping
    except Exception:
        pass
    
    if best_woe_df is None:
        # Fallback: simple equal-frequency binning
        try:
            bins = pd.qcut(data_non_missing[col], q=5, duplicates='drop', retbins=True)[1]
            bins[0] = -np.inf
            bins[-1] = np.inf
            woe_df, iv_value, mapping = _compute_woe_for_bins(
                data, col, target_col, bins, total_events, total_non_events,
                missing_mask
            )
            best_iv = iv_value
            best_woe_df = woe_df
            best_mapping = mapping
        except Exception:
            return None, None, None
    
    return best_woe_df, best_iv, best_mapping


def _create_quantile_bins(series, n_bins, min_pct):
    """Create quantile-based bins ensuring minimum percentage per bin."""
    try:
        _, bins = pd.qcut(series, q=n_bins, duplicates='drop', retbins=True)
        bins[0] = -np.inf
        bins[-1] = np.inf
        return bins
    except Exception:
        return None


def _tree_based_binning(data, col, target_col, max_bins, min_pct):
    """Use decision tree to find optimal split points."""
    try:
        from sklearn.tree import DecisionTreeClassifier
        
        X = data[col].values.reshape(-1, 1)
        y = data[target_col].values
        
        # Remove any NaN
        valid_mask = ~np.isnan(X.ravel())
        X = X[valid_mask]
        y = y[valid_mask]
        
        if len(X) == 0:
            return None
        
        min_samples = max(int(len(X) * min_pct), 50)
        
        tree = DecisionTreeClassifier(
            max_leaf_nodes=max_bins,
            min_samples_leaf=min_samples,
            random_state=42
        )
        tree.fit(X, y)
        
        # Extract thresholds
        thresholds = tree.tree_.threshold[tree.tree_.threshold != -2]
        thresholds = np.sort(np.unique(thresholds))
        
        if len(thresholds) == 0:
            return None
        
        bins = np.concatenate([[-np.inf], thresholds, [np.inf]])
        return bins
    except ImportError:
        return None
    except Exception:
        return None


