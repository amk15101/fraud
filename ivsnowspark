def plot_woe(woe_details, variable_name):
    """
    Plot WOE values for a specific variable.
    
    Parameters:
    -----------
    woe_details : dict
        WOE details dictionary from calculate_woe_iv results
    variable_name : str
        Name of the variable to plot
    """
    try:
        import matplotlib.pyplot as plt
    except ImportError:
        print("matplotlib is required for plotting. Install with: pip install matplotlib")
        return
    
    if variable_name not in woe_details:
        print(f"Variable '{variable_name}' not found in WOE details")
        return
    
    df = woe_details[variable_name]
    
    fig, axes = plt.subplots(1, 2, figsize=(14, 5))
    
    # Plot 1: WOE values
    bins_str = [str(b)[:20] for b in df['bin']]
    axes[0].bar(range(len(bins_str)), df['woe'], color=['red' if w < 0 else 'green' for w in df['woe']])
    axes[0].set_xticks(range(len(bins_str)))
    axes[0].set_xticklabels(bins_str, rotation=45, ha='right', fontsize=8)
    axes[0].set_title(f'WOE - {variable_name}')
    axes[0].set_ylabel('WOE')
    axes[0].axhline(y=0, color='black', linestyle='--', linewidth=0.5)
    
    # Plot 2: Event rate and count
    ax1 = axes[1]
    ax2 = ax1.twinx()
    
    ax1.bar(range(len(bins_str)), df['count'], alpha=0.3, color='blue', label='Count')
    ax2.plot(range(len(bins_str)), df['event_rate'], 'ro-', label='Event Rate')
    
    ax1.set_xticks(range(len(bins_str)))
    ax1.set_xticklabels(bins_str, rotation=45, ha='right', fontsize=8)
    ax1.set_title(f'Distribution - {variable_name}')
    ax1.set_ylabel('Count')
    ax2.set_ylabel('Event Rate')
    
    lines1, labels1 = ax1.get_legend_handles_labels()
    lines2, labels2 = ax2.get_legend_handles_labels()
    ax1.legend(lines1 + lines2, labels1 + labels2, loc='upper right')
    
    plt.tight_layout()
    plt.show()


def filter_by_iv(results, min_iv=0.02, max_iv=0.5):
    """
    Filter variables by IV threshold.
    
    Parameters:
    -----------
    results : dict
        Output from calculate_woe_iv
    min_iv : float
        Minimum IV threshold (default: 0.02)
    max_iv : float
        Maximum IV threshold to exclude suspicious variables (default: 0.5)
    
    Returns:
    --------
    list of variable names that pass the IV filter
    """
    iv_summary = results['iv_summary']
    filtered = iv_summary[(iv_summary['iv'] >= min_iv) & (iv_summary['iv'] <= max_iv)]
    return filtered['variable'].tolist()


def get_woe_transformed_spark_df(results, sp_df, target_col, selected_vars=None):
    """
    Get a Spark DataFrame with only selected WOE-transformed variables.
    
    Parameters:
    -----------
    results : dict
        Output from calculate_woe_iv
    sp_df : pyspark.sql.DataFrame
        Original Spark DataFrame
    target_col : str
        Target column name
    selected_vars : list
        List of variables to include (if None, uses all with IV > 0.02)
    
    Returns:
    --------
    pyspark.sql.DataFrame with WOE-transformed selected variables
    """
    if selected_vars is None:
        selected_vars = filter_by_iv(results)
    
    woe_cols = [var + '_woe' for var in selected_vars]
    available_cols = [col for col in [target_col] + woe_cols 
                      if col in results['transformed_df'].columns]
    
    return results['transformed_df'].select(available_cols)


