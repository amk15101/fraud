/*=============================================================*/

/* ============ CHANGE THESE PARAMETERS ============ */
%fraud_rules(
    input_ds=YOUR_DATASET_NAME,   /* <-- Replace with your dataset */
    target=fraud_trans,             /* <-- Your fraud indicator (0/1) */
    min_hit_rate=0.10              /* <-- Minimum 10% hit rate */
);
