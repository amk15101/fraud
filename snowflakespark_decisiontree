def evaluate_rule_on_snowpark(sp_df, rule, target_col='FRAUD_TRANS'):
    """Evaluate a rule on full Snowpark DataFrame."""
    filter_cond = None
    for cond in rule['conditions']:
        c = F.col(cond['variable']) > cond['threshold'] if cond['direction'] == '>' \
            else F.col(cond['variable']) < cond['threshold']
        filter_cond = c if filter_cond is None else filter_cond & c

    total = sp_df.agg(F.count('*').alias('T'), F.sum(F.col(target_col)).alias('TF')).collect()[0]
    rule_stats = sp_df.filter(filter_cond).agg(
        F.count('*').alias('S'), F.sum(F.col(target_col)).alias('RF')).collect()[0]

    support = rule_stats['S'] or 0
    fraud = rule_stats['RF'] or 0
    hr = fraud / support if support > 0 else 0

    print(f"\n  Rule: {rule['rule_string']}")
    print(f"  Flagged: {support:,} | Fraud: {fraud:,} | HR: {hr:.2%} | "
          f"Capture: {fraud/(total['TF'] or 1):.2%}")
    return {'support': support, 'fraud': fraud, 'hit_rate': hr}


def apply_fraud_rules(sp_df, rules):
    """Apply rules as flag columns to Snowpark DataFrame."""
    result_df = sp_df
    for i, rule in enumerate(rules[:10], 1):
        filter_cond = None
        for cond in rule['conditions']:
            c = F.col(cond['variable']) > cond['threshold'] if cond['direction'] == '>' \
                else F.col(cond['variable']) < cond['threshold']
            filter_cond = c if filter_cond is None else filter_cond & c
        result_df = result_df.with_column(
            f'FRAUD_RULE_{i}', F.when(filter_cond, F.lit(1)).otherwise(F.lit(0)))
    return result_df


