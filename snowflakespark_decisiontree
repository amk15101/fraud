def classify_iv(iv):
    if iv < 0.02: return "Not Predictive"
    elif iv < 0.1: return "Weak"
    elif iv < 0.3: return "Medium"
    elif iv < 0.5: return "Strong"
    else: return "Very Strong"


def get_pareto_optimal(cutoffs, max_return=5):
    if not cutoffs:
        return []
    seen = set()
    pareto = []
    for c in sorted(cutoffs, key=lambda x: -x['hit_rate'])[:max_return]:
        key = (c['variable'], c['direction'], round(c['threshold'], 4))
        if key not in seen:
            seen.add(key)
            pareto.append(c)
    for c in sorted(cutoffs, key=lambda x: -x['fraud_captured'])[:max_return]:
        key = (c['variable'], c['direction'], round(c['threshold'], 4))
        if key not in seen:
            seen.add(key)
            pareto.append(c)
    return pareto[:max_return * 2]


def generate_snowpark_filter(rule):
    parts = []
    for cond in rule['conditions']:
        col, d, t = cond['variable'], cond['direction'], cond['threshold']
        if d == '>':
            parts.append(f'(F.col("{col}") > {t})')
        else:
            parts.append(f'(F.col("{col}") < {t})')
    return f"sp_df.filter({' & '.join(parts)})"


def calculate_iv_single_query(sp_df, col, target_col, n_bins=10):
    """IV calculation - 1 query in Snowflake using NTILE."""
    try:
        binned_stats = sp_df.select(
            F.col(col), F.col(target_col),
            F.ntile(n_bins).over(Window.order_by(F.col(col))).alias('BIN')
        ).group_by('BIN').agg(
            F.count('*').alias('BIN_COUNT'),
            F.sum(F.col(target_col)).alias('BIN_EVENTS'),
            F.sum(F.when(F.col(target_col) == 0, 1).otherwise(0)).alias('BIN_NON_EVENTS')
        ).collect()

        total_events = sum(r['BIN_EVENTS'] or 0 for r in binned_stats)
        total_non_events = sum(r['BIN_NON_EVENTS'] or 0 for r in binned_stats)
        if total_events == 0 or total_non_events == 0:
            return 0.0

        iv = 0.0
        for r in binned_stats:
            pe = max((r['BIN_EVENTS'] or 0) / total_events, 0.0001)
            pne = max((r['BIN_NON_EVENTS'] or 0) / total_non_events, 0.0001)
            iv += (pne - pe) * np.log(pne / pe)
        return float(iv)
    except:
        return 0.0


def find_cutoffs_single_query(sp_df, col, target_col, n_thresholds=20,
                               min_hit_rate=0.05, min_support=50, total_fraud=1):
    """Find cutoffs - 1 query per variable using NTILE + cumulative logic."""
    try:
        bin_stats = sp_df.select(
            F.col(col), F.col(target_col),
            F.ntile(n_thresholds).over(Window.order_by(F.col(col))).alias('BIN')
        ).group_by('BIN').agg(
            F.count('*').alias('BIN_COUNT'),
            F.sum(F.col(target_col)).alias('BIN_FRAUD'),
            F.max(F.col(col)).alias('BIN_MAX'),
            F.min(F.col(col)).alias('BIN_MIN')
        ).order_by('BIN').collect()

        if not bin_stats:
            return []

        bins = [{'count': r['BIN_COUNT'] or 0, 'fraud': r['BIN_FRAUD'] or 0,
                 'max_val': r['BIN_MAX'], 'min_val': r['BIN_MIN']} for r in bin_stats]

        total_count = sum(b['count'] for b in bins)
        total_fraud_col = sum(b['fraud'] for b in bins)
        if total_fraud_col == 0:
            return []

        cutoffs = []
        cum_count, cum_fraud = 0, 0

        for b in bins:
            cum_count += b['count']
            cum_fraud += b['fraud']

            right_count = total_count - cum_count
            right_fraud = total_fraud_col - cum_fraud
            threshold = b['max_val']

            if threshold is None:
                continue

            # col > threshold
            if right_count >= min_support and right_count > 0:
                hr = right_fraud / right_count
                if hr >= min_hit_rate:
                    cutoffs.append({
                        'variable': col, 'direction': '>',
                        'threshold': float(threshold),
                        'hit_rate': float(hr),
                        'fraud_captured': int(right_fraud),
                        'support': int(right_count),
                        'pct_fraud_captured': float(right_fraud / total_fraud)
                    })

            # col < min_val of this bin
            left_threshold = b['min_val']
            if left_threshold is not None and cum_count >= min_support and cum_count > 0:
                hr_l = cum_fraud / cum_count
                if hr_l >= min_hit_rate:
                    cutoffs.append({
                        'variable': col, 'direction': '<',
                        'threshold': float(left_threshold),
                        'hit_rate': float(hr_l),
                        'fraud_captured': int(cum_fraud),
                        'support': int(cum_count),
                        'pct_fraud_captured': float(cum_fraud / total_fraud)
                    })

        return get_pareto_optimal(cutoffs, max_return=5)
    except Exception as e:
        print(f"    Cutoff error for {col}: {e}")
        return []


def evaluate_combo_snowpark(sp_df, conditions, target_col, min_support=50, total_fraud=1):
    """Evaluate one combination in Snowflake - 1 query."""
    try:
        filter_cond = None
        rule_parts = []
        for cond in conditions:
            col, d, t = cond['variable'], cond['direction'], cond['threshold']
            c = F.col(col) > t if d == '>' else F.col(col) < t
            filter_cond = c if filter_cond is None else filter_cond & c
            rule_parts.append(f"{col} {d} {t:.4f}")

        stats = sp_df.filter(filter_cond).agg(
            F.count('*').alias('SUPPORT'),
            F.sum(F.col(target_col)).alias('FRAUD')
        ).collect()[0]

        support = stats['SUPPORT'] or 0
        fraud = stats['FRAUD'] or 0

        if support >= min_support and support > 0:
            return {
                'conditions': conditions,
                'hit_rate': float(fraud / support),
                'fraud_captured': int(fraud),
                'support': int(support),
                'rule_string': ' AND '.join(rule_parts),
                'pct_fraud_captured': float(fraud / total_fraud) if total_fraud > 0 else 0
            }
    except:
        pass
    return None


def save_rules_to_csv(results, output_path='fraud_rules_output'):
    """Save all results to CSV files."""
    if not os.path.exists(output_path):
        os.makedirs(output_path)

    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
    saved_files = {}

    # Save rules
    rules = results.get('rules', [])
    if rules:
        rows = []
        for i, rule in enumerate(rules, 1):
            row = {
                'Rule_Number': i,
                'Rule_String': rule['rule_string'],
                'Hit_Rate': round(rule['hit_rate'], 6),
                'Hit_Rate_Pct': f"{rule['hit_rate']*100:.2f}%",
                'Fraud_Captured': rule['fraud_captured'],
                'Support': rule['support'],
                'Num_Variables': rule.get('n_variables', 0),
                'Pct_Fraud_Captured': round(rule.get('pct_fraud_captured', 0), 6),
            }
            for j, cond in enumerate(rule.get('conditions', []), 1):
                row[f'Var_{j}'] = cond.get('variable', '')
                row[f'Dir_{j}'] = cond.get('direction', '')
                row[f'Thresh_{j}'] = cond.get('threshold', '')
            rows.append(row)

        df = pd.DataFrame(rows)
        f = os.path.join(output_path, f'all_rules_{timestamp}.csv')
        df.to_csv(f, index=False)
        saved_files['all_rules'] = f
        print(f"  ✅ Rules CSV: {f} ({len(rows)} rules)")

    # Save IV table
    iv_table = results.get('iv_table')
    if iv_table is not None and len(iv_table) > 0:
        f = os.path.join(output_path, f'iv_table_{timestamp}.csv')
        iv_table.to_csv(f, index=False)
        saved_files['iv_table'] = f
        print(f"  ✅ IV Table: {f}")

    # Save SQL
    if rules:
        f = os.path.join(output_path, f'rules_sql_{timestamp}.sql')
        with open(f, 'w') as fh:
            fh.write(f"-- Generated: {datetime.now()}\n\n")
            for i, rule in enumerate(rules[:20], 1):
                conds = [f"{c['variable']} {c['direction']} {c['threshold']}" 
                         for c in rule['conditions']]
                fh.write(f"-- Rule #{i}: HR={rule['hit_rate']:.2%}, Fraud={rule['fraud_captured']}\n")
                fh.write(f"SELECT * FROM YOUR_TABLE WHERE {' AND '.join(conds)};\n\n")
        saved_files['sql'] = f
        print(f"  ✅ SQL File: {f}")

    # Save summary
    f = os.path.join(output_path, f'summary_{timestamp}.txt')
    with open(f, 'w') as fh:
        fh.write(f"FRAUD RULE MINING SUMMARY\n{'='*50}\n")
        fh.write(f"Generated: {datetime.now()}\n")
        fh.write(f"Total Rules: {len(rules)}\n\n")
        if results.get('best_rule'):
            br = results['best_rule']
            fh.write(f"BEST RULE: {br['rule_string']}\n")
            fh.write(f"Hit Rate: {br['hit_rate']:.2%}\n")
            fh.write(f"Fraud: {br['fraud_captured']}\n")
            fh.write(f"Support: {br['support']}\n\n")
        for i, rule in enumerate(rules[:50], 1):
            fh.write(f"#{i}: {rule['rule_string']} | HR:{rule['hit_rate']:.2%} | F:{rule['fraud_captured']}\n")
    saved_files['summary'] = f
    print(f"  ✅ Summary: {f}")

    return saved_files


