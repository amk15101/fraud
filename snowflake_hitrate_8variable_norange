# =============================================================================
# FUNCTION 1: CATEGORICAL RULE GENERATION (SNOWPARK) - UNCHANGED
# =============================================================================

def generate_fraud_rules_snowpark(
    sp_df: DataFrame,
    target_flag: str = "FRAUD_TRANS",
    target_amt: str = "FRAUD_AMT",
    min_hit_rate: float = 0.10,
    max_cardinality: int = 50,
    min_support: int = 100,
    max_combination_depth: int = 3,
    exclude_patterns: Optional[List[str]] = None
):
    """
    Generate categorical fraud rules.
    Only uses TRUE categorical variables (low cardinality).
    Does NOT bin numeric variables into ranges.
    """
    if exclude_patterns is None:
        exclude_patterns = [
            'id', 'ID', 'Id', '_id', '_ID',
            'date', 'Date', 'DATE', '_dt', '_DT',
            'time', 'Time', 'TIME', 'timestamp', 'Timestamp',
            'key', 'Key', 'KEY',
            'name', 'Name', 'NAME',
            'address', 'Address',
            'phone', 'Phone',
            'email', 'Email',
            'ssn', 'SSN',
            'account_number', 'acct_no', 'acct_num',
            'card_number', 'card_no', 'card_num',
            'ip_address', 'ip_addr',
            'uuid', 'UUID'
        ]

    print("=" * 80)
    print("FRAUD RULE GENERATION ENGINE - CATEGORICAL RULES (SNOWPARK)")
    print("Rule Format: var = 'value' (NO ranges, NO binning)")
    print("=" * 80)

    print("\n[STEP 1] Filtering columns...")
    all_columns = sp_df.columns
    candidate_columns = [c for c in all_columns if c not in [target_flag, target_amt]]

    def should_exclude(col_name: str) -> bool:
        for pattern in exclude_patterns:
            if pattern.lower() in col_name.lower():
                return True
        return False

    candidate_columns = [c for c in candidate_columns if not should_exclude(c)]
    print(f"  Columns after pattern exclusion: {len(candidate_columns)}")

    print("\n[STEP 2] Checking cardinality & identifying categorical columns...")
    total_count = sp_df.count()
    total_fraud = sp_df.filter(F.col(target_flag) == 1).count()
    overall_fraud_rate = total_fraud / total_count if total_count > 0 else 0

    print(f"  Total records: {total_count:,}")
    print(f"  Total frauds: {total_fraud:,}")
    print(f"  Overall fraud rate: {overall_fraud_rate:.4%}")

    schema = sp_df.schema
    dtype_map = {}
    for field in schema.fields:
        dtype_map[field.name] = str(field.datatype)

    numeric_types = ('LongType', 'IntegerType', 'FloatType', 'DoubleType', 'DecimalType')

    valid_columns = []

    for col in candidate_columns:
        dtype = dtype_map.get(col, "")

        if any(nt in dtype for nt in numeric_types):
            distinct_count = sp_df.select(F.col(col)).distinct().count()
            if distinct_count <= 10:
                valid_columns.append(col)
                print(f"    {col}: numeric but low cardinality ({distinct_count}) - INCLUDED as categorical")
            else:
                print(f"    {col}: numeric with {distinct_count} levels - SKIPPED (handled by threshold rules)")
            continue

        distinct_count = sp_df.select(F.col(col)).distinct().count()
        if distinct_count <= max_cardinality:
            valid_columns.append(col)
        else:
            print(f"    {col}: high cardinality ({distinct_count}) - SKIPPED")

    print(f"\n  Valid categorical columns: {len(valid_columns)}")
    print(f"  Columns: {valid_columns}")

    working_df = sp_df

    print("\n[STEP 3] Generating single-variable categorical rules...")
    all_rules = []

    for col in valid_columns:
        try:
            rule_stats = working_df.group_by(F.col(col)).agg(
                F.count("*").alias("TOTAL_COUNT"),
                F.sum(F.col(target_flag).cast(IntegerType())).alias("FRAUD_COUNT"),
                F.sum(
                    F.when(F.col(target_flag) == 1, F.col(target_amt)).otherwise(F.lit(0))
                ).alias("FRAUD_AMOUNT_SUM"),
                F.avg(
                    F.when(F.col(target_flag) == 1, F.col(target_amt)).otherwise(F.lit(None))
                ).alias("AVG_FRAUD_AMOUNT")
            ).collect()

            for row in rule_stats:
                value = row[col]
                count = row['TOTAL_COUNT']
                fraud_count = row['FRAUD_COUNT'] or 0
                fraud_amount = row['FRAUD_AMOUNT_SUM'] or 0
                avg_fraud_amt = row['AVG_FRAUD_AMOUNT'] or 0

                if count >= min_support and count > 0:
                    hit_rate = fraud_count / count
                    if hit_rate >= min_hit_rate:
                        rule = {
                            'rule_description': f"{col} = '{value}'",
                            'rule_columns': col,
                            'rule_values': str(value),
                            'rule_type': 'categorical',
                            'combination_depth': 1,
                            'total_records': count,
                            'fraud_count': fraud_count,
                            'hit_rate': hit_rate,
                            'fraud_amount_sum': fraud_amount,
                            'avg_fraud_amount': avg_fraud_amt,
                            'lift': hit_rate / overall_fraud_rate if overall_fraud_rate > 0 else 0,
                            'fraud_capture_rate': fraud_count / total_fraud if total_fraud > 0 else 0
                        }
                        all_rules.append(rule)
        except Exception as e:
            print(f"  Warning: Error processing column {col}: {str(e)}")
            continue

