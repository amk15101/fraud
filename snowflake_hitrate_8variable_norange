    rules_df['rule_rank'] = range(1, len(rules_df) + 1)
    rules_df['hit_rate_pct'] = rules_df['hit_rate'].apply(lambda x: f"{x:.2%}")
    rules_df['fraud_capture_rate_pct'] = rules_df['fraud_capture_rate'].apply(lambda x: f"{x:.2%}")

    print(f"\n{'=' * 80}")
    print(f"CATEGORICAL RULES SUMMARY")
    print(f"{'=' * 80}")
    print(f"  Total rules generated: {len(rules_df)}")
    print(f"  1-variable rules: {len(rules_df[rules_df['combination_depth'] == 1])}")
    if max_combination_depth >= 2:
        print(f"  2-variable rules: {len(rules_df[rules_df['combination_depth'] == 2])}")
    if max_combination_depth >= 3:
        print(f"  3-variable rules: {len(rules_df[rules_df['combination_depth'] == 3])}")
    if max_combination_depth >= 4:
        print(f"  4-variable rules: {len(rules_df[rules_df['combination_depth'] == 4])}")
    if max_combination_depth >= 5:
        print(f"  5-variable rules: {len(rules_df[rules_df['combination_depth'] == 5])}")
    print(f"  Max hit rate: {rules_df['hit_rate'].max():.2%}")
    print(f"  Max lift: {rules_df['lift'].max():.2f}x")

    return rules_df


# =============================================================================
# FUNCTION 2: APPLY RULES TO DATAFRAME (SNOWPARK) - UNCHANGED
# =============================================================================

def apply_rules_to_dataframe_snowpark(
    sp_df: DataFrame,
    rules_df: pd.DataFrame,
    target_flag: str = "FRAUD_TRANS",
    top_n_rules: int = None
):
    """Apply rules to flag transactions. Only supports =, >, <= operators (NO ranges)."""

    if top_n_rules:
        rules_to_apply = rules_df.head(top_n_rules)
    else:
        rules_to_apply = rules_df

    flagged_df = sp_df
    rule_columns = []

    for idx, row in rules_to_apply.iterrows():
        rule_col_name = f"RULE_{row.get('final_rank', row.get('rule_rank', idx + 1))}"
        rule_columns.append(rule_col_name)

        rule_type = row.get('rule_type', 'categorical')
        condition = None

        if rule_type == 'categorical':
            columns = row['rule_columns'].split(' | ')
            values = row['rule_values'].split(' | ')

            for col, val in zip(columns, values):
                col = col.strip()
                val = val.strip()

                if val == 'None' or val == 'null':
                    cond = F.col(col).is_null()
                else:
                    try:
                        numeric_val = float(val)
                        cond = F.col(col) == F.lit(numeric_val)
                    except (ValueError, TypeError):
                        cond = F.col(col) == F.lit(val)

                condition = cond if condition is None else (condition & cond)

        elif rule_type == 'greater_than':
            col = row['rule_columns']
            threshold = float(row['threshold_value'])
            condition = F.col(col) > F.lit(threshold)

        elif rule_type == 'less_than_equal':
            col = row['rule_columns']
            threshold = float(row['threshold_value'])
            condition = F.col(col) <= F.lit(threshold)

        elif rule_type == 'multi_threshold':
            rule_desc = row['rule_description']
            parts = rule_desc.split(' AND ')
            for part in parts:
                part = part.strip()
                if ' > ' in part:
                    col_part, val_part = part.split(' > ', 1)
                    cond = F.col(col_part.strip()) > F.lit(float(val_part.strip()))
                elif ' <= ' in part:
                    col_part, val_part = part.split(' <= ', 1)
                    cond = F.col(col_part.strip()) <= F.lit(float(val_part.strip()))
                else:
                    continue
                condition = cond if condition is None else (condition & cond)

        if condition is not None:
            flagged_df = flagged_df.with_column(
                rule_col_name,
                F.when(condition, F.lit(1)).otherwise(F.lit(0))
            )
        else:
            flagged_df = flagged_df.with_column(rule_col_name, F.lit(0))

    # Combined flag
    if rule_columns:
        combined_expr = F.lit(0)
        for rc in rule_columns:
            combined_expr = combined_expr + F.col(rc)

        flagged_df = flagged_df.with_column(
            "ANY_RULE_TRIGGERED",
            F.when(combined_expr > 0, F.lit(1)).otherwise(F.lit(0))
        )
        flagged_df = flagged_df.with_column(
            "NUM_RULES_TRIGGERED",
            combined_expr
        )

    # Performance summary
    print("\n" + "=" * 80)
    print("RULE APPLICATION PERFORMANCE")
    print("Rule Format: var > X, var <= X, or var = 'value' (NO RANGES)")
    print("=" * 80)

    total = flagged_df.count()
    total_fraud = flagged_df.filter(F.col(target_flag) == 1).count()
    triggered = flagged_df.filter(F.col("ANY_RULE_TRIGGERED") == 1)
    triggered_count = triggered.count()
    triggered_fraud = triggered.filter(F.col(target_flag) == 1).count()

    print(f"  Total records: {total:,}")
    print(f"  Records flagged by any rule: {triggered_count:,} ({triggered_count/total:.2%})")
    print(f"  Fraud captured: {triggered_fraud:,} / {total_fraud:,} ({triggered_fraud/total_fraud:.2%})")
    if triggered_count > 0:
        print(f"  Precision (hit rate) of combined rules: {triggered_fraud/triggered_count:.2%}")

    return flagged_df


# =============================================================================
# FUNCTION 3: NUMERIC THRESHOLD RULES (SNOWPARK) - UP TO 8 VARIABLES
# =============================================================================

def generate_numeric_threshold_rules_snowpark(
    sp_df: DataFrame,
    target_flag: str = "FRAUD_TRANS",
    target_amt: str = "FRAUD_AMT",
    min_hit_rate: float = 0.10,
    min_support: int = 100,
    exclude_patterns: Optional[List[str]] = None,
    percentile_thresholds: List[float] = None,
    max_variable_depth: int = 8
):
    """
    Generate numeric threshold rules with up to 8 variables.
    ONLY creates rules in format:
        variable > threshold
        variable <= threshold
    NEVER creates range/between rules.
    """
    if exclude_patterns is None:
        exclude_patterns = [
            'id', 'ID', 'Id', '_id', '_ID',
            'date', 'Date', 'DATE', '_dt', '_DT',
            'time', 'Time', 'TIME', 'timestamp',
            'key', 'Key', 'KEY',
            'name', 'Name', 'NAME',
            'address', 'phone', 'email', 'ssn',
            'account_number', 'acct_no', 'card_number',
            'ip_address', 'uuid'
        ]

    if percentile_thresholds is None:
        percentile_thresholds = [0.05, 0.10, 0.25, 0.50, 0.75, 0.90, 0.95]

    print("=" * 80)
    print("NUMERIC THRESHOLD RULE GENERATION (SNOWPARK)")
    print(f"MAX VARIABLE DEPTH: {max_variable_depth}")
    print("RULE FORMAT: var > X  or  var <= X  (NO RANGES / NO BETWEEN)")
    print("=" * 80)

    total_count = sp_df.count()
    total_fraud = sp_df.filter(F.col(target_flag) == 1).count()
    overall_fraud_rate = total_fraud / total_count if total_count > 0 else 0

    print(f"  Total records: {total_count:,}")
    print(f"  Total frauds: {total_fraud:,}")
    print(f"  Overall fraud rate: {overall_fraud_rate:.4%}")

    def should_exclude(col_name: str) -> bool:
        for pattern in exclude_patterns:
            if pattern.lower() in col_name.lower():
                return True
        return False

    schema = sp_df.schema
    numeric_snowpark_types = (
        'LongType', 'IntegerType', 'FloatType', 'DoubleType', 'DecimalType'
    )
    numeric_columns = []
    for field in schema.fields:
        dtype_str = str(field.datatype)
        if any(nt in dtype_str for nt in numeric_snowpark_types):
            if field.name not in [target_flag, target_amt] and not should_exclude(field.name):
                numeric_columns.append(field.name)

    print(f"\n  Numeric columns to analyze: {len(numeric_columns)}")
    print(f"  Columns: {numeric_columns}")

    # =========================================================================
    # HELPERS
    # =========================================================================
    def build_condition_from_description(rule_desc: str):
        parts = rule_desc.split(' AND ')
        condition = None
        for part in parts:
            part = part.strip()
            if ' > ' in part:
                col_part, val_part = part.split(' > ', 1)
                cond = F.col(col_part.strip()) > F.lit(float(val_part.strip()))
            elif ' <= ' in part:
                col_part, val_part = part.split(' <= ', 1)
                cond = F.col(col_part.strip()) <= F.lit(float(val_part.strip()))
            else:
                continue
            condition = cond if condition is None else (condition & cond)
        return condition

    def get_columns_from_description(rule_desc: str) -> set:
        parts = rule_desc.split(' AND ')
        cols = set()
        for part in parts:
            part = part.strip()
            if ' > ' in part:
                col_part = part.split(' > ', 1)[0].strip()
                cols.add(col_part)
            elif ' <= ' in part:
                col_part = part.split(' <= ', 1)[0].strip()
                cols.add(col_part)
        return cols

    def test_rule(rule_desc: str, min_obs: int = 100):
        condition = build_condition_from_description(rule_desc)
        if condition is None:
            return None
        try:
            stats = sp_df.filter(condition).agg(
                F.count("*").alias("TOTAL_COUNT"),
                F.sum(F.col(target_flag).cast(IntegerType())).alias("FRAUD_COUNT"),
                F.sum(
                    F.when(F.col(target_flag) == 1, F.col(target_amt)).otherwise(F.lit(0))
                ).alias("FRAUD_AMOUNT_SUM")
            ).collect()[0]

            count = stats['TOTAL_COUNT']
            fraud = stats['FRAUD_COUNT'] or 0
            fraud_amt = stats['FRAUD_AMOUNT_SUM'] or 0

            if count >= min_obs and count > 0:
                hit_rate = fraud / count
                if hit_rate >= min_hit_rate:
                    return {
                        'total_records': count,
                        'fraud_count': fraud,
                        'hit_rate': hit_rate,
                        'fraud_amount_sum': fraud_amt,
                        'avg_fraud_amount': fraud_amt / fraud if fraud > 0 else 0,
                        'lift': hit_rate / overall_fraud_rate if overall_fraud_rate > 0 else 0,
                        'fraud_capture_rate': fraud / total_fraud if total_fraud > 0 else 0
                    }
        except Exception:
            pass
        return None

    # =========================================================================
    # PRE-COMPUTE PERCENTILES
    # =========================================================================
    print("\n  Pre-computing percentiles for all numeric columns...")
    column_percentiles = {}

    for col in numeric_columns:
        try:
            select_exprs = [
                F.call_function("APPROX_PERCENTILE", F.col(col), F.lit(pct)).alias(f"P{i}")
                for i, pct in enumerate(percentile_thresholds)
            ]
            percentile_row = sp_df.select(*select_exprs).collect()

            if percentile_row:
                row_data = percentile_row[0]
                values = []
                for i in range(len(percentile_thresholds)):
                    val = row_data[f"P{i}"]
                    values.append(float(val) if val is not None else 0.0)

                seen = set()
                unique = []
                for pct, val in zip(percentile_thresholds, values):
                    if val not in seen:
                        seen.add(val)
                        unique.append((pct, val))
                column_percentiles[col] = unique
        except Exception as e:
            print(f"    Warning: Could not get percentiles for {col}: {e}")
            continue

    print(f"  Percentiles computed for {len(column_percentiles)} columns")

    # =========================================================================
    # INITIALIZE ALL RULE LISTS (FIX FOR UnboundLocalError)
    # =========================================================================
    two_var_rules = []
    three_var_rules = []
    four_var_rules = []
    five_var_rules = []
    six_var_rules = []
    seven_var_rules = []
    eight_var_rules = []

   # =========================================================================
    # PHASE 1: 1-VARIABLE RULES (continued)
    # =========================================================================
    for col in numeric_columns:
        if col not in column_percentiles:
            continue

        for pct, threshold in column_percentiles[col]:
            # Test: var > threshold
            rule_desc = f"{col} > {threshold:.4f}"
            result = test_rule(rule_desc, min_obs=min_support)
            if result:
                all_threshold_rules.append({
                    'rule_description': rule_desc,
                    'rule_columns': col,
                    'rule_type': 'greater_than',
                    'threshold_value': threshold,
                    'percentile': pct,
                    'combination_depth': 1,
                    **result
                })

            # Test: var <= threshold
            rule_desc = f"{col} <= {threshold:.4f}"
            result = test_rule(rule_desc, min_obs=min_support)
            if result:
                all_threshold_rules.append({
                    'rule_description': rule_desc,
                    'rule_columns': col,
                    'rule_type': 'less_than_equal',
                    'threshold_value': threshold,
                    'percentile': pct,
                    'combination_depth': 1,
                    **result
                })

    print(f"  1-variable rules found: {len(all_threshold_rules)}")

    # =========================================================================
    # PHASE 2: 2-VARIABLE RULES
    # =========================================================================
    if max_variable_depth >= 2 and all_threshold_rules:
        print("\n" + "-" * 60)
        print("  PHASE 2: Building 2-variable rules...")
        print("-" * 60)

        sorted_1var = sorted(all_threshold_rules, key=lambda x: x['hit_rate'], reverse=True)
        top_1var = sorted_1var[:15]

        for i in range(len(top_1var)):
            for j in range(i + 1, len(top_1var)):
                rule_i = top_1var[i]
                rule_j = top_1var[j]

                if rule_i['rule_columns'] == rule_j['rule_columns']:
                    continue

                rule_desc = f"{rule_i['rule_description']} AND {rule_j['rule_description']}"
                result = test_rule(rule_desc, min_obs=min_support)
                if result:
                    cols_used = f"{rule_i['rule_columns']} | {rule_j['rule_columns']}"
                    two_var_rules.append({
                        'rule_description': rule_desc,
                        'rule_columns': cols_used,
                        'rule_type': 'multi_threshold',
                        'threshold_value': None,
                        'percentile': None,
                        'combination_depth': 2,
                        **result
                    })

        all_threshold_rules.extend(two_var_rules)
        print(f"  2-variable rules found: {len(two_var_rules)}")
    else:
        print("\n  PHASE 2: Skipped")

    # =========================================================================
    # GENERIC FUNCTION FOR PHASES 3-8
    # =========================================================================
    def build_next_depth_rules(
        previous_depth_rules: list,
        current_depth: int,
        top_n_seeds: int,
        top_n_single: int,
        min_obs: int
    ) -> list:
        """Build rules for current_depth by combining previous depth seeds with 1-var rules."""
        new_rules = []

        if not previous_depth_rules:
            return new_rules

        sorted_prev = sorted(
            previous_depth_rules,
            key=lambda x: x['hit_rate'] * x['fraud_capture_rate'],
            reverse=True
        )
        top_prev = sorted_prev[:top_n_seeds]

        sorted_1var_local = sorted(all_threshold_rules, key=lambda x: x['hit_rate'], reverse=True)
        top_1var_local = [r for r in sorted_1var_local if r['combination_depth'] == 1][:top_n_single]

        for combo_rule in top_prev:
            used_cols = get_columns_from_description(combo_rule['rule_description'])

            for single_rule in top_1var_local:
                add_col = single_rule['rule_columns']
                if add_col in used_cols:
                    continue

                rule_desc = f"{combo_rule['rule_description']} AND {single_rule['rule_description']}"
                result = test_rule(rule_desc, min_obs=min_obs)
                if result:
                    all_cols = used_cols | {add_col}
                    new_rules.append({
                        'rule_description': rule_desc,
                        'rule_columns': ' | '.join(sorted(all_cols)),
                        'rule_type': 'multi_threshold',
                        'threshold_value': None,
                        'percentile': None,
                        'combination_depth': current_depth,
                        **result
                    })

        return new_rules

    # =========================================================================
    # PHASE 3: 3-VARIABLE RULES
    # =========================================================================
    if max_variable_depth >= 3 and two_var_rules:
        print("\n" + "-" * 60)
        print("  PHASE 3: Building 3-variable rules...")
        print("-" * 60)

        three_var_rules = build_next_depth_rules(
            previous_depth_rules=two_var_rules,
            current_depth=3,
            top_n_seeds=10,
            top_n_single=12,
            min_obs=max(min_support // 2, 50)
        )
        all_threshold_rules.extend(three_var_rules)
        print(f"  3-variable rules found: {len(three_var_rules)}")
    else:
        print("\n  PHASE 3: Skipped")

    # =========================================================================
    # PHASE 4: 4-VARIABLE RULES
    # =========================================================================
    if max_variable_depth >= 4 and three_var_rules:
        print("\n" + "-" * 60)
        print("  PHASE 4: Building 4-variable rules...")
        print("-" * 60)

        four_var_rules = build_next_depth_rules(
            previous_depth_rules=three_var_rules,
            current_depth=4,
            top_n_seeds=8,
            top_n_single=10,
            min_obs=max(min_support // 4, 20)
        )
        all_threshold_rules.extend(four_var_rules)
        print(f"  4-variable rules found: {len(four_var_rules)}")
    else:
        print("\n  PHASE 4: Skipped")

    # =========================================================================
    # PHASE 5: 5-VARIABLE RULES
    # =========================================================================
    if max_variable_depth >= 5 and four_var_rules:
        print("\n" + "-" * 60)
        print("  PHASE 5: Building 5-variable rules...")
        print("-" * 60)

        five_var_rules = build_next_depth_rules(
            previous_depth_rules=four_var_rules,
            current_depth=5,
            top_n_seeds=5,
            top_n_single=8,
            min_obs=max(min_support // 8, 10)
        )
        all_threshold_rules.extend(five_var_rules)
        print(f"  5-variable rules found: {len(five_var_rules)}")
    else:
        print("\n  PHASE 5: Skipped")

    # =========================================================================
    # PHASE 6: 6-VARIABLE RULES
    # =========================================================================
    if max_variable_depth >= 6 and five_var_rules:
        print("\n" + "-" * 60)
        print("  PHASE 6: Building 6-variable rules...")
        print("-" * 60)

        six_var_rules = build_next_depth_rules(
            previous_depth_rules=five_var_rules,
            current_depth=6,
            top_n_seeds=5,
            top_n_single=8,
            min_obs=max(min_support // 10, 10)
        )
        all_threshold_rules.extend(six_var_rules)
        print(f"  6-variable rules found: {len(six_var_rules)}")
    else:
        print("\n  PHASE 6: Skipped")

    # =========================================================================
    # PHASE 7: 7-VARIABLE RULES
    # =========================================================================
    if max_variable_depth >= 7 and six_var_rules:
        print("\n" + "-" * 60)
        print("  PHASE 7: Building 7-variable rules...")
        print("-" * 60)

        seven_var_rules = build_next_depth_rules(
            previous_depth_rules=six_var_rules,
            current_depth=7,
            top_n_seeds=4,
            top_n_single=7,
            min_obs=max(min_support // 12, 5)
        )
        all_threshold_rules.extend(seven_var_rules)
        print(f"  7-variable rules found: {len(seven_var_rules)}")
    else:
        print("\n  PHASE 7: Skipped")

    # =========================================================================
    # PHASE 8: 8-VARIABLE RULES
    # =========================================================================
    if max_variable_depth >= 8 and seven_var_rules:
        print("\n" + "-" * 60)
        print("  PHASE 8: Building 8-variable rules...")
        print("-" * 60)

        eight_var_rules = build_next_depth_rules(
            previous_depth_rules=seven_var_rules,
            current_depth=8,
            top_n_seeds=3,
            top_n_single=6,
            min_obs=max(min_support // 15, 5)
        )
        all_threshold_rules.extend(eight_var_rules)
        print(f"  8-variable rules found: {len(eight_var_rules)}")
    else:
        print("\n  PHASE 8: Skipped")

    # =========================================================================
    # COMPILE RESULTS
    # =========================================================================
    if not all_threshold_rules:
        print("\n  No threshold rules found meeting criteria!")
        return pd.DataFrame()

    threshold_rules_df = pd.DataFrame(all_threshold_rules)
    threshold_rules_df = threshold_rules_df.sort_values(
        by=['hit_rate', 'fraud_count'],
        ascending=[False, False]
    ).reset_index(drop=True)
    threshold_rules_df['rule_rank'] = range(1, len(threshold_rules_df) + 1)
    threshold_rules_df['hit_rate_pct'] = threshold_rules_df['hit_rate'].apply(lambda x: f"{x:.2%}")
    threshold_rules_df['fraud_capture_rate_pct'] = threshold_rules_df['fraud_capture_rate'].apply(
        lambda x: f"{x:.2%}"
    )

    print(f"\n{'=' * 80}")
    print(f"NUMERIC THRESHOLD RULES SUMMARY")
    print(f"ALL RULES ARE: var > X  or  var <= X  (NO RANGES)")
    print(f"{'=' * 80}")
    print(f"  Total threshold rules found: {len(threshold_rules_df)}")
    for depth in range(1, 9):
        count = len(threshold_rules_df[threshold_rules_df['combination_depth'] == depth])
        if count > 0:
            print(f"  {depth}-variable rules: {count}")
    print(f"  Max hit rate: {threshold_rules_df['hit_rate'].max():.2%}")
    print(f"  Max lift: {threshold_rules_df['lift'].max():.2f}x")

    print(f"\n  Top 20 Threshold Rules:")
    print(f"  {'-' * 90}")
    for _, row in threshold_rules_df.head(20).iterrows():
        print(f"  #{row['rule_rank']:3d} | Hit Rate: {row['hit_rate_pct']:>7s} | "
              f"Fraud: {row['fraud_count']:>6,} | Records: {row['total_records']:>8,} | "
              f"Lift: {row['lift']:.1f}x | Vars: {row['combination_depth']}")
        print(f"       | Rule: {row['rule_description'][:85]}")
        print(f"  {'-' * 90}")

    return threshold_rules_df


# =============================================================================
# FUNCTION 4: COMBINE AND RANK ALL RULES (SNOWPARK) - UNCHANGED
# =============================================================================

def combine_and_rank_all_rules_snowpark(
    categorical_rules: pd.DataFrame,
    threshold_rules: pd.DataFrame,
    remove_redundant: bool = True
):
    """
    Combine categorical and threshold rules, rank by composite score.
    All rules are in format:
        - var = 'value' (categorical)
        - var > X (numeric greater than)
        - var <= X (numeric less than or equal)
    NO RANGES / NO BETWEEN.
    """
    print("=" * 80)
    print("COMBINING AND RANKING ALL RULES (SNOWPARK)")
    print("Rule formats: var = 'value', var > X, var <= X (NO RANGES)")
    print("=" * 80)

    if 'rule_type' not in categorical_rules.columns:
        categorical_rules['rule_type'] = 'categorical'
    if 'threshold_value' not in categorical_rules.columns:
        categorical_rules['threshold_value'] = None
    if 'percentile' not in categorical_rules.columns:
        categorical_rules['percentile'] = None

    if 'rule_values' not in threshold_rules.columns:
        threshold_rules['rule_values'] = threshold_rules['threshold_value'].astype(str)
    if 'avg_fraud_amount' not in threshold_rules.columns:
        threshold_rules['avg_fraud_amount'] = (
            threshold_rules['fraud_amount_sum'] / threshold_rules['fraud_count']
        ).fillna(0)

    common_cols = [
        'rule_description', 'rule_columns', 'rule_type', 'combination_depth',
        'total_records', 'fraud_count', 'hit_rate', 'fraud_amount_sum',
        'lift', 'fraud_capture_rate'
    ]

    cat_subset = categorical_rules[[c for c in common_cols if c in categorical_rules.columns]]
    thr_subset = threshold_rules[[c for c in common_cols if c in threshold_rules.columns]]

    combined = pd.concat([cat_subset, thr_subset], ignore_index=True)

    combined['composite_score'] = (
        combined['hit_rate'] * np.log1p(combined['fraud_count']) * combined['lift']
    )

    combined = combined.sort_values(
        by=['composite_score', 'hit_rate', 'fraud_count'],
        ascending=[False, False, False]
    ).reset_index(drop=True)

    combined['final_rank'] = range(1, len(combined) + 1)
    combined['hit_rate_pct'] = combined['hit_rate'].apply(lambda x: f"{x:.2%}")
    combined['fraud_capture_pct'] = combined['fraud_capture_rate'].apply(lambda x: f"{x:.2%}")

    if remove_redundant:
        print(f"  Rules before redundancy removal: {len(combined)}")
        combined = combined.drop_duplicates(subset=['rule_description'], keep='first')
        combined = combined.reset_index(drop=True)
        combined['final_rank'] = range(1, len(combined) + 1)
        print(f"  Rules after redundancy removal: {len(combined)}")

    range_rules = combined[combined['rule_type'] == 'range']
    if len(range_rules) > 0:
        print(f"  WARNING: Found {len(range_rules)} range rules — REMOVING them!")
        combined = combined[combined['rule_type'] != 'range'].reset_index(drop=True)
        combined['final_rank'] = range(1, len(combined) + 1)

    print(f"\n  FINAL RULE COUNT: {len(combined)}")
    print(f"  Rule types present: {combined['rule_type'].unique().tolist()}")

    print(f"\n  Top 20 Rules by Composite Score:")
    print(f"  {'=' * 76}")

    for _, row in combined.head(20).iterrows():
        print(f"  #{row['final_rank']:3d} | Hit Rate: {row['hit_rate_pct']:>7s} | "
              f"Lift: {row['lift']:>5.1f}x | Fraud: {row['fraud_count']:>6,} | "
              f"Records: {row['total_records']:>8,} | Type: {row['rule_type']}")
        print(f"       | Rule: {row['rule_description'][:70]}")
        print(f"  {'-' * 76}")

    return combined


