def fraud_rule_miner(sp_df, target_col='FRAUD_TRANS', min_hit_rate=0.10, 
                     max_variables=None, min_iv=0.02, n_bins=20,
                     min_rule_support=50, min_precision=0.05):
    """
    Mines fraud detection rules from Snowpark DataFrame.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
        Input dataframe with features and target
    target_col : str
        Target column name (1=fraud, 0=non-fraud)
    min_hit_rate : float
        Minimum hit rate (precision) for rules (default 10%)
    max_variables : int or None
        Maximum number of variables in a rule. If None, tries 1 to N.
    min_iv : float
        Minimum Information Value to consider a variable useful
    n_bins : int
        Number of bins for WOE calculation
    min_rule_support : int
        Minimum number of records a rule must capture
    min_precision : float
        Minimum precision threshold for individual variable cutoffs
        
    Returns:
    --------
    dict with:
        - 'rules': List of discovered rules
        - 'iv_table': IV summary for all variables
        - 'woe_details': WOE binning details per variable
        - 'best_rule': Best rule meeting hit rate criteria
    """
    
    # Convert Snowpark DF to Pandas for rule mining
    print("=" * 70)
    print("FRAUD RULE MINER - Starting Analysis")
    print("=" * 70)
    print(f"\nTarget: {target_col}")
    print(f"Minimum Hit Rate Required: {min_hit_rate * 100:.1f}%")
    print(f"\nConverting Snowpark DataFrame to Pandas...")
    
    pdf = sp_df.to_pandas()
    print(f"Dataset Shape: {pdf.shape}")
    print(f"Fraud Rate: {pdf[target_col].mean() * 100:.4f}%")
    print(f"Fraud Count: {pdf[target_col].sum()}")
    print(f"Non-Fraud Count: {(pdf[target_col] == 0).sum()}")
    
    # Identify numeric columns (exclude target)
    numeric_cols = pdf.select_dtypes(include=[np.number]).columns.tolist()
    numeric_cols = [c for c in numeric_cols if c != target_col]
    
    print(f"\nNumeric Features Found: {len(numeric_cols)}")
    print(f"Features: {numeric_cols}")
    
    # =========================================================================
    # STEP 1: Calculate WOE and IV for each variable
    # =========================================================================
    print("\n" + "=" * 70)
    print("STEP 1: WOE & IV CALCULATION")
    print("=" * 70)
    
    iv_results = {}
    woe_details = {}
    variable_cutoffs = {}
    
    for col in numeric_cols:
        iv, woe_table, cutoffs = calculate_woe_iv(
            pdf, col, target_col, n_bins=n_bins
        )
        iv_results[col] = iv
        woe_details[col] = woe_table
        if cutoffs:
            variable_cutoffs[col] = cutoffs
    
    # Create IV summary table
    iv_df = pd.DataFrame({
        'Variable': list(iv_results.keys()),
        'IV': list(iv_results.values())
    }).sort_values('IV', ascending=False).reset_index(drop=True)
    
    iv_df['Predictive_Power'] = iv_df['IV'].apply(classify_iv)
    
    print("\n--- Information Value Summary ---")
    print(iv_df.to_string(index=False))
    
    # Filter variables with minimum IV
    useful_vars = iv_df[iv_df['IV'] >= min_iv]['Variable'].tolist()
    print(f"\nVariables with IV >= {min_iv}: {len(useful_vars)}")
    print(f"Selected Variables: {useful_vars}")
    
    if len(useful_vars) == 0:
        print("WARNING: No variables meet minimum IV threshold. Using all variables.")
        useful_vars = numeric_cols
    
    # =========================================================================
    # STEP 2: Find optimal cutoffs for each variable using WOE
    # =========================================================================
    print("\n" + "=" * 70)
    print("STEP 2: FINDING OPTIMAL CUTOFFS PER VARIABLE")
    print("=" * 70)
    
    all_cutoff_rules = []
    
    for col in useful_vars:
        cutoffs = find_optimal_cutoffs(
            pdf, col, target_col, n_bins=n_bins, 
            min_hit_rate=min_hit_rate * 0.5,  # Relaxed for individual vars
            min_support=min_rule_support
        )
        
        if cutoffs:
            variable_cutoffs[col] = cutoffs
            for cutoff in cutoffs:
                all_cutoff_rules.append(cutoff)
                print(f"  {col}: {cutoff['direction']} {cutoff['threshold']:.4f} | "
                      f"Hit Rate: {cutoff['hit_rate']:.4f} | "
                      f"Fraud Captured: {cutoff['fraud_captured']} | "
                      f"Support: {cutoff['support']}")
    
    # =========================================================================
    # STEP 3: Generate single-variable rules
    # =========================================================================
    print("\n" + "=" * 70)
    print("STEP 3: SINGLE VARIABLE RULES")
    print("=" * 70)
    
    single_var_rules = []
    
    for cutoff in all_cutoff_rules:
        if cutoff['hit_rate'] >= min_hit_rate:
            rule = {
                'conditions': [cutoff],
                'hit_rate': cutoff['hit_rate'],
                'fraud_captured': cutoff['fraud_captured'],
                'support': cutoff['support'],
                'n_variables': 1,
                'rule_string': f"{cutoff['variable']} {cutoff['direction']} {cutoff['threshold']:.4f}"
            }
            single_var_rules.append(rule)
            print(f"  RULE: {rule['rule_string']} | Hit Rate: {rule['hit_rate']:.2%} | "
                  f"Fraud: {rule['fraud_captured']} | Support: {rule['support']}")
    
    print(f"\nSingle-variable rules meeting {min_hit_rate:.0%} hit rate: {len(single_var_rules)}")
    
    # =========================================================================
    # STEP 4: Generate multi-variable combination rules
    # =========================================================================
    print("\n" + "=" * 70)
    print("STEP 4: MULTI-VARIABLE COMBINATION RULES")
    print("=" * 70)
    
    if max_variables is None:
        max_variables = min(len(useful_vars), 6)  # Cap at 6 to avoid explosion
    
    multi_var_rules = []
    
    # Group cutoffs by variable
    cutoffs_by_var = {}
    for cutoff in all_cutoff_rules:
        var = cutoff['variable']
        if var not in cutoffs_by_var:
            cutoffs_by_var[var] = []
        cutoffs_by_var[var].append(cutoff)
    
    vars_with_cutoffs = list(cutoffs_by_var.keys())
    
    # Try combinations of 2, 3, 4, ... variables
    for n_vars in range(2, max_variables + 1):
        print(f"\n  --- Trying {n_vars}-variable combinations ---")
        rules_found = 0
        
        if len(vars_with_cutoffs) < n_vars:
            print(f"  Not enough variables with cutoffs. Skipping.")
            continue
        
        for var_combo in combinations(vars_with_cutoffs, n_vars):
            # For each combination of variables, try all cutoff combinations
            cutoff_lists = [cutoffs_by_var[v] for v in var_combo]
            
            # Generate all combinations of cutoffs (one per variable)
            combo_rules = generate_cutoff_combinations(
                cutoff_lists, pdf, target_col, 
                min_hit_rate=min_hit_rate,
                min_support=min_rule_support
            )
            
            for rule in combo_rules:
                rule['n_variables'] = n_vars
                multi_var_rules.append(rule)
                rules_found += 1
        
        print(f"  Rules found with {n_vars} variables: {rules_found}")
        
        # If we found good rules, we can optionally stop
        if rules_found > 0 and n_vars >= 3:
            good_rules = [r for r in multi_var_rules if r['hit_rate'] >= min_hit_rate]
            if len(good_rules) >= 10:
                print(f"  Found sufficient rules. Stopping at {n_vars} variables.")
                break
    
    # =========================================================================
    # STEP 5: Compile and rank all rules
    # =========================================================================
    print("\n" + "=" * 70)
    print("STEP 5: FINAL RULE RANKING")
    print("=" * 70)
    
    all_rules = single_var_rules + multi_var_rules
    
    # Sort by hit_rate descending, then by fraud_captured descending
    all_rules.sort(key=lambda x: (-x['hit_rate'], -x['fraud_captured']))
    
    # Filter rules meeting minimum hit rate
    qualifying_rules = [r for r in all_rules if r['hit_rate'] >= min_hit_rate]
    
    print(f"\nTotal rules generated: {len(all_rules)}")
    print(f"Rules meeting {min_hit_rate:.0%} hit rate: {len(qualifying_rules)}")
    
    if qualifying_rules:
        print(f"\n{'='*70}")
        print("TOP 20 RULES (by Hit Rate)")
        print(f"{'='*70}")
        
        for i, rule in enumerate(qualifying_rules[:20], 1):
            print(f"\n  Rule #{i}:")
            print(f"    Conditions: {rule['rule_string']}")
            print(f"    Hit Rate:       {rule['hit_rate']:.2%}")
            print(f"    Fraud Captured: {rule['fraud_captured']}")
            print(f"    Support:        {rule['support']}")
            print(f"    # Variables:    {rule['n_variables']}")
        
        best_rule = qualifying_rules[0]
        print(f"\n{'='*70}")
        print("BEST RULE:")
        print(f"{'='*70}")
        print(f"  {best_rule['rule_string']}")
        print(f"  Hit Rate: {best_rule['hit_rate']:.2%}")
        print(f"  Fraud Captured: {best_rule['fraud_captured']}")
        print(f"  Support: {best_rule['support']}")
    else:
        print("\nWARNING: No rules found meeting the minimum hit rate!")
        print("Showing best available rules:")
        best_rule = all_rules[0] if all_rules else None
        for i, rule in enumerate(all_rules[:10], 1):
            print(f"\n  Rule #{i}:")
            print(f"    Conditions: {rule['rule_string']}")
            print(f"    Hit Rate:       {rule['hit_rate']:.2%}")
            print(f"    Fraud Captured: {rule['fraud_captured']}")
            print(f"    Support:        {rule['support']}")
    
    # =========================================================================
    # STEP 6: Generate Snowpark filter expression for best rule
    # =========================================================================
    if best_rule:
        print(f"\n{'='*70}")
        print("SNOWPARK FILTER EXPRESSION FOR BEST RULE:")
        print(f"{'='*70}")
        snowpark_expr = generate_snowpark_filter(best_rule)
        print(f"  {snowpark_expr}")
    
    return {
        'rules': qualifying_rules if qualifying_rules else all_rules[:20],
        'all_rules': all_rules,
        'iv_table': iv_df,
        'woe_details': woe_details,
        'variable_cutoffs': variable_cutoffs,
        'best_rule': best_rule,
        'useful_variables': useful_vars
    }


def calculate_woe_iv(pdf, col, target_col, n_bins=20):
    """
    Calculate Weight of Evidence and Information Value for a variable.
    
    Returns:
    --------
    iv : float - Information Value
    woe_table : DataFrame - WOE table with bins
    cutoffs : list - Suggested cutoffs based on WOE
    """
    
    # Handle missing values
    data = pdf[[col, target_col]].copy()
    data = data.dropna(subset=[col])
    
    if data[col].nunique() <= 1:
        return 0.0, pd.DataFrame(), []
    
    # Create bins
    try:
        if data[col].nunique() <= n_bins:
            # Use actual values as bins for low-cardinality
            data['bin'] = data[col]
        else:
            # Use quantile-based binning
            data['bin'] = pd.qcut(data[col], q=n_bins, duplicates='drop')
    except Exception:
        try:
            data['bin'] = pd.cut(data[col], bins=n_bins, duplicates='drop')
        except Exception:
            return 0.0, pd.DataFrame(), []
    
    # Calculate WOE table
    total_events = data[target_col].sum()  # Total frauds
    total_non_events = (data[target_col] == 0).sum()  # Total non-frauds
    
    if total_events == 0 or total_non_events == 0:
        return 0.0, pd.DataFrame(), []
    
    grouped = data.groupby('bin', observed=True).agg(
        total_count=(target_col, 'count'),
        event_count=(target_col, 'sum')
    ).reset_index()
    
    grouped['non_event_count'] = grouped['total_count'] - grouped['event_count']
    grouped['event_rate'] = grouped['event_count'] / grouped['total_count']
    grouped['pct_events'] = grouped['event_count'] / total_events
    grouped['pct_non_events'] = grouped['non_event_count'] / total_non_events
    
    # Avoid division by zero
    grouped['pct_events'] = grouped['pct_events'].replace(0, 0.0001)
    grouped['pct_non_events'] = grouped['pct_non_events'].replace(0, 0.0001)
    
    # WOE = ln(% non-events / % events)
    # Positive WOE = more non-fraud (good)
    # Negative WOE = more fraud (bad)
    grouped['woe'] = np.log(grouped['pct_non_events'] / grouped['pct_events'])
    grouped['iv_component'] = (grouped['pct_non_events'] - grouped['pct_events']) * grouped['woe']
    
    iv = grouped['iv_component'].sum()
    
    # Find cutoffs where WOE is very negative (fraud pockets)
    cutoffs = []
    
    # Sort by bin to find thresholds
    if hasattr(grouped['bin'].iloc[0], 'left'):
        # Interval bins
        grouped = grouped.sort_values('bin', key=lambda x: x.apply(lambda v: v.left if hasattr(v, 'left') else v))
        
        for _, row in grouped.iterrows():
            if row['event_rate'] > data[target_col].mean() * 2:  # At least 2x avg fraud rate
                bin_val = row['bin']
                if hasattr(bin_val, 'right'):
                    cutoffs.append({
                        'variable': col,
                        'bin_left': bin_val.left,
                        'bin_right': bin_val.right,
                        'event_rate': row['event_rate'],
                        'woe': row['woe'],
                        'support': row['total_count']
                    })
    
    return iv, grouped, cutoffs


def classify_iv(iv):
    """Classify IV into predictive power categories."""
    if iv < 0.02:
        return "Not Predictive"
    elif iv < 0.1:
        return "Weak"
    elif iv < 0.3:
        return "Medium"
    elif iv < 0.5:
        return "Strong"
    else:
        return "Very Strong (Suspicious)"


def find_optimal_cutoffs(pdf, col, target_col, n_bins=20, 
                         min_hit_rate=0.05, min_support=50):
    """
    Find optimal cutoff points for a variable using > or < only.
    Tests multiple thresholds and returns those with best hit rates.
    
    Returns list of cutoff dictionaries with:
        - variable, direction (> or <), threshold, hit_rate, fraud_captured, support
    """
    
    data = pdf[[col, target_col]].dropna(subset=[col])
    
    if data[col].nunique() <= 1:
        return []
    
    total_fraud = data[target_col].sum()
    cutoffs = []
    
    # Generate candidate thresholds using percentiles
    percentiles = np.linspace(1, 99, min(n_bins * 2, 50))
    thresholds = np.percentile(data[col].values, percentiles)
    thresholds = np.unique(thresholds)
    
    # Also add thresholds based on WOE bin boundaries
    try:
        _, bins = pd.qcut(data[col], q=n_bins, retbins=True, duplicates='drop')
        thresholds = np.unique(np.concatenate([thresholds, bins]))
    except Exception:
        pass
    
    best_gt_cutoff = None  # Best "greater than" cutoff
    best_lt_cutoff = None  # Best "less than" cutoff
    
    for thresh in thresholds:
        # Test: variable > threshold
        mask_gt = data[col] > thresh
        subset_gt = data[mask_gt]
        
        if len(subset_gt) >= min_support:
            fraud_in_subset = subset_gt[target_col].sum()
            hit_rate_gt = fraud_in_subset / len(subset_gt) if len(subset_gt) > 0 else 0
            
            if hit_rate_gt >= min_hit_rate:
                cutoff_gt = {
                    'variable': col,
                    'direction': '>',
                    'threshold': thresh,
                    'hit_rate': hit_rate_gt,
                    'fraud_captured': int(fraud_in_subset),
                    'support': int(len(subset_gt)),
                    'pct_fraud_captured': fraud_in_subset / total_fraud if total_fraud > 0 else 0
                }
                
                if best_gt_cutoff is None or hit_rate_gt > best_gt_cutoff['hit_rate']:
                    best_gt_cutoff = cutoff_gt
                
                # Also keep cutoffs with good balance of hit rate and fraud captured
                cutoffs.append(cutoff_gt)
        
        # Test: variable < threshold
        mask_lt = data[col] < thresh
        subset_lt = data[mask_lt]
        
        if len(subset_lt) >= min_support:
            fraud_in_subset = subset_lt[target_col].sum()
            hit_rate_lt = fraud_in_subset / len(subset_lt) if len(subset_lt) > 0 else 0
            
            if hit_rate_lt >= min_hit_rate:
                cutoff_lt = {
                    'variable': col,
                    'direction': '<',
                    'threshold': thresh,
                    'hit_rate': hit_rate_lt,
                    'fraud_captured': int(fraud_in_subset),
                    'support': int(len(subset_lt)),
                    'pct_fraud_captured': fraud_in_subset / total_fraud if total_fraud > 0 else 0
                }
                
                if best_lt_cutoff is None or hit_rate_lt > best_lt_cutoff['hit_rate']:
                    best_lt_cutoff = cutoff_lt
                
                cutoffs.append(cutoff_lt)
    
    # Deduplicate and keep best cutoffs
    # Strategy: Keep Pareto-optimal cutoffs (best hit_rate for given support level)
    final_cutoffs = get_pareto_optimal_cutoffs(cutoffs)
    
    return final_cutoffs


def get_pareto_optimal_cutoffs(cutoffs, max_return=5):
    """
    Return Pareto-optimal cutoffs balancing hit_rate and fraud_captured.
    Keeps diverse set of cutoffs - some with high hit rate, some with high capture.
    """
    if not cutoffs:
        return []
    
    # Sort by hit_rate descending
    sorted_by_hr = sorted(cutoffs, key=lambda x: -x['hit_rate'])
    
    # Sort by fraud_captured descending
    sorted_by_fc = sorted(cutoffs, key=lambda x: -x['fraud_captured'])
    
    # Keep top by hit rate
    pareto = []
    seen = set()
    
    # Best hit rate cutoffs
    for c in sorted_by_hr[:max_return]:
        key = (c['variable'], c['direction'], round(c['threshold'], 6))
        if key not in seen:
            seen.add(key)
            pareto.append(c)
    
    # Best fraud capture cutoffs
    for c in sorted_by_fc[:max_return]:
        key = (c['variable'], c['direction'], round(c['threshold'], 6))
        if key not in seen:
            seen.add(key)
            pareto.append(c)
    
    # Also add a "balanced" cutoff (product of hit_rate and pct_fraud_captured)
    for c in cutoffs:
        c['score'] = c['hit_rate'] * c.get('pct_fraud_captured', 0)
    
    sorted_by_score = sorted(cutoffs, key=lambda x: -x.get('score', 0))
    for c in sorted_by_score[:max_return]:
        key = (c['variable'], c['direction'], round(c['threshold'], 6))
        if key not in seen:
            seen.add(key)
            pareto.append(c)
    
    return pareto[:max_return * 2]


def generate_cutoff_combinations(cutoff_lists, pdf, target_col, 
                                  min_hit_rate=0.10, min_support=50):
    """
    Generate rule combinations from multiple variable cutoffs.
    Each variable contributes one condition (> or <).
    
    Parameters:
    -----------
    cutoff_lists : list of lists
        Each inner list contains cutoff dicts for one variable
    pdf : DataFrame
        Full dataset
    target_col : str
        Target column
    min_hit_rate : float
        Minimum hit rate
    min_support : int
        Minimum records matching rule
        
    Returns:
    --------
    list of rule dictionaries
    """
    from itertools import product
    
    rules = []
    
    # Limit combinations to avoid explosion
    # Take top 3 cutoffs per variable
    trimmed_lists = []
    for cl in cutoff_lists:
        sorted_cl = sorted(cl, key=lambda x: -x['hit_rate'])[:3]
        trimmed_lists.append(sorted_cl)
    
    # Generate all combinations
    total_combos = 1
    for tl in trimmed_lists:
        total_combos *= len(tl)
    
    if total_combos > 10000:
        # Too many combinations, further trim
        trimmed_lists = [sorted(cl, key=lambda x: -x['hit_rate'])[:2] for cl in trimmed_lists]
    
    for combo in product(*trimmed_lists):
        # Apply all conditions simultaneously
        mask = pd.Series([True] * len(pdf), index=pdf.index)
        
        conditions = []
        rule_parts = []
        
        for cutoff in combo:
            col = cutoff['variable']
            direction = cutoff['direction']
            threshold = cutoff['threshold']
            
            if direction == '>':
                mask = mask & (pdf[col] > threshold)
            else:  # '<'
                mask = mask & (pdf[col] < threshold)
            
            conditions.append(cutoff)
            rule_parts.append(f"{col} {direction} {threshold:.4f}")
        
        subset = pdf[mask]
        support = len(subset)
        
        if support >= min_support:
            fraud_count = subset[target_col].sum()
            hit_rate = fraud_count / support if support > 0 else 0
            
            if hit_rate >= min_hit_rate * 0.8:  # Slightly relaxed to capture near-misses
                rule = {
                    'conditions': list(combo),
                    'hit_rate': hit_rate,
                    'fraud_captured': int(fraud_count),
                    'support': int(support),
                    'n_variables': len(combo),
                    'rule_string': ' AND '.join(rule_parts),
                    'pct_fraud_captured': fraud_count / pdf[target_col].sum() if pdf[target_col].sum() > 0 else 0
                }
                rules.append(rule)
    
    return rules


def generate_snowpark_filter(rule):
    """
    Generate a Snowpark-compatible filter expression string for a rule.
    
    Parameters:
    -----------
    rule : dict
        Rule dictionary with 'conditions' list
        
    Returns:
    --------
    str : Snowpark filter expression
    """
    filter_parts = []
    
    for condition in rule['conditions']:
        col = condition['variable']
        direction = condition['direction']
        threshold = condition['threshold']
        
        if direction == '>':
            filter_parts.append(f'(F.col("{col}") > {threshold})')
        else:
            filter_parts.append(f'(F.col("{col}") < {threshold})')
    
    snowpark_filter = ' & '.join(filter_parts)
    return f"sp_df.filter({snowpark_filter})"


def apply_best_rule_snowpark(sp_df, rule, target_col='FRAUD_TRANS'):
    """
    Apply the best rule to a Snowpark DataFrame and return flagged records.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    rule : dict - Rule dictionary from fraud_rule_miner
    target_col : str - Target column name
    
    Returns:
    --------
    Snowpark DataFrame with flagged fraud records
    """
    
    filter_condition = None
    
    for condition in rule['conditions']:
        col = condition['variable']
        direction = condition['direction']
        threshold = condition['threshold']
        
        if direction == '>':
            cond = F.col(col) > threshold
        else:
            cond = F.col(col) < threshold
        
        if filter_condition is None:
            filter_condition = cond
        else:
            filter_condition = filter_condition & cond
    
    # Add a flag column
    flagged_df = sp_df.with_column(
        'FRAUD_RULE_FLAG',
        F.when(filter_condition, F.lit(1)).otherwise(F.lit(0))
    )
    
    return flagged_df


def evaluate_rule_on_snowpark(sp_df, rule, target_col='FRAUD_TRANS'):
    """
    Evaluate a rule directly on Snowpark DataFrame (without converting to pandas).
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    rule : dict - Rule dictionary
    target_col : str - Target column
    
    Returns:
    --------
    dict with evaluation metrics
    """
    
    filter_condition = None
    
    for condition in rule['conditions']:
        col = condition['variable']
        direction = condition['direction']
        threshold = condition['threshold']
        
        if direction == '>':
            cond = F.col(col) > threshold
        else:
            cond = F.col(col) < threshold
        
        if filter_condition is None:
            filter_condition = cond
        else:
            filter_condition = filter_condition & cond
    
    # Total counts
    total_stats = sp_df.agg(
        F.count('*').alias('TOTAL_COUNT'),
        F.sum(F.col(target_col)).alias('TOTAL_FRAUD')
    ).collect()[0]
    
    total_count = total_stats['TOTAL_COUNT']
    total_fraud = total_stats['TOTAL_FRAUD']
    
    # Filtered counts
    filtered_df = sp_df.filter(filter_condition)
    filtered_stats = filtered_df.agg(
        F.count('*').alias('RULE_COUNT'),
        F.sum(F.col(target_col)).alias('RULE_FRAUD')
    ).collect()[0]
    
    rule_count = filtered_stats['RULE_COUNT']
    rule_fraud = filtered_stats['RULE_FRAUD']
    
    hit_rate = rule_fraud / rule_count if rule_count > 0 else 0
    fraud_capture_rate = rule_fraud / total_fraud if total_fraud > 0 else 0
    
    results = {
