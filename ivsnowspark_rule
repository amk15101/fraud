def advanced_fraud_rule_miner(sp_df, target_col='FRAUD_TRANS', min_hit_rate=0.10,
                               max_variables=5, n_bins=20, min_support=50,
                               use_decision_tree=True, tree_depth=4):
    """
    Advanced version that also uses Decision Tree to guide rule discovery.
    
    This helps find complex fraud pockets that simple threshold scanning might miss.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    target_col : str
    min_hit_rate : float
    max_variables : int
    n_bins : int
    min_support : int
    use_decision_tree : bool - Whether to use DT for initial rule hints
    tree_depth : int - Max depth of decision tree
    
    Returns:
    --------
    dict with rules and analysis
    """
    
    print("=" * 70)
    print("ADVANCED FRAUD RULE MINER")
    print("=" * 70)
    
    pdf = sp_df.to_pandas()
    
    numeric_cols = pdf.select_dtypes(include=[np.number]).columns.tolist()
    numeric_cols = [c for c in numeric_cols if c != target_col]
    
    # First run basic miner
    basic_results = fraud_rule_miner(
        sp_df, target_col=target_col, min_hit_rate=min_hit_rate,
        max_variables=max_variables, n_bins=n_bins, min_rule_support=min_support
    )
    
    tree_rules = []
    
    if use_decision_tree:
        print(f"\n{'='*70}")
        print("DECISION TREE GUIDED RULE EXTRACTION")
        print(f"{'='*70}")
        
        try:
            from sklearn.tree import DecisionTreeClassifier
            from sklearn.tree import export_text
            
            # Prepare data
            X = pdf[numeric_cols].fillna(0)
            y = pdf[target_col]
            
            # Fit decision tree with class weight to handle imbalance
            dt = DecisionTreeClassifier(
                max_depth=tree_depth,
                min_samples_leaf=min_support,
                class_weight='balanced',
                random_state=42
            )
            dt.fit(X, y)
            
            # Extract rules from tree
            tree_rules = extract_rules_from_tree(
                dt, numeric_cols, pdf, target_col, 
                min_hit_rate=min_hit_rate, min_support=min_support
            )
            
            print(f"\n  Decision Tree Rules Found: {len(tree_rules)}")
            for i, rule in enumerate(tree_rules[:10], 1):
                print(f"\n  DT Rule #{i}:")
                print(f"    {rule['rule_string']}")
                print(f"    Hit Rate: {rule['hit_rate']:.2%} | Fraud: {rule['fraud_captured']} | Support: {rule['support']}")
        
        except ImportError:
            print("  sklearn not available. Skipping decision tree analysis.")
        except Exception as e:
            print(f"  Decision tree analysis failed: {e}")
    
    # Combine all rules
    all_rules = basic_results.get('rules', []) + tree_rules
    all_rules.sort(key=lambda x: (-x['hit_rate'], -x['fraud_captured']))
    
    # Remove duplicates (same rule_string)
    seen_rules = set()
    unique_rules = []
    for rule in all_rules:
        if rule['rule_string'] not in seen_rules:
            seen_rules.add(rule['rule_string'])
            unique_rules.append(rule)
    
    # Final filtering
    qualifying_rules = [r for r in unique_rules if r['hit_rate'] >= min_hit_rate]
    
    print(f"\n{'='*70}")
    print("FINAL COMBINED RESULTS")
    print(f"{'='*70}")
    print(f"Total Qualifying Rules: {len(qualifying_rules)}")
    
    if qualifying_rules:
        print(f"\nTOP 10 BEST RULES:")
        for i, rule in enumerate(qualifying_rules[:10], 1):
            print(f"\n  #{i}: {rule['rule_string']}")
            print(f"      Hit Rate: {rule['hit_rate']:.2%} | "
                  f"Fraud: {rule['fraud_captured']} | "
                  f"Support: {rule['support']} | "
                  f"Vars: {rule['n_variables']}")
    
    basic_results['rules'] = qualifying_rules
    basic_results['tree_rules'] = tree_rules
    basic_results['best_rule'] = qualifying_rules[0] if qualifying_rules else basic_results.get('best_rule')
    
    return basic_results


def extract_rules_from_tree(dt, feature_names, pdf, target_col, 
                            min_hit_rate=0.10, min_support=50):
    """
    Extract rules from a fitted decision tree, converting to > / < format only.
    
    Parameters:
    -----------
    dt : DecisionTreeClassifier
    feature_names : list
    pdf : DataFrame
    target_col : str
    min_hit_rate : float
    min_support : int
    
    Returns:
    --------
    list of rule dictionaries
    """
    
    tree = dt.tree_
    rules = []
    
    def recurse(node, conditions):
        # If leaf node
        if tree.children_left[node] == tree.children_right[node]:
            # Evaluate this path
            if conditions:
                mask = pd.Series([True] * len(pdf), index=pdf.index)
                rule_parts = []
                condition_list = []
                
                for col, direction, threshold in conditions:
                    if direction == '<=':
                        # Convert <= to <  (using slightly higher threshold)
                        mask = mask & (pdf[col] < threshold)
                        cond = {
                            'variable': col,
                            'direction': '<',
                            'threshold': threshold
                        }
                        rule_parts.append(f"{col} < {threshold:.4f}")
                    else:
                        # Convert > to >
                        mask = mask & (pdf[col] > threshold)
                        cond = {
                            'variable': col,
                            'direction': '>',
                            'threshold': threshold
                        }
                        rule_parts.append(f"{col} > {threshold:.4f}")
                    
                    condition_list.append(cond)
                
                subset = pdf[mask]
                support = len(subset)
                
                if support >= min_support:
                    fraud_count = subset[target_col].sum()
                    hit_rate = fraud_count / support if support > 0 else 0
                    
                    if hit_rate >= min_hit_rate:
                        # Count unique variables
                        unique_vars = set(c['variable'] for c in condition_list)
                        
                        rule = {
                            'conditions': condition_list,
                            'hit_rate': hit_rate,
                            'fraud_captured': int(fraud_count),
                            'support': int(support),
                            'n_variables': len(unique_vars),
                            'rule_string': ' AND '.join(rule_parts),
                            'pct_fraud_captured': fraud_count / pdf[target_col].sum() if pdf[target_col].sum() > 0 else 0
                        }
                        rules.append(rule)
            return
        
        # Get feature and threshold for this node
        feature_idx = tree.feature[node]
        threshold = tree.threshold[node]
        col = feature_names[feature_idx]
        
        # Left child: feature <= threshold
        left_conditions = conditions + [(col, '<=', threshold)]
        recurse(tree.children_left[node], left_conditions)
        
        # Right child: feature > threshold
        right_conditions = conditions + [(col, '>', threshold)]
        recurse(tree.children_right[node], right_conditions)
    
    recurse(0, [])
    
    return rules


def iterative_rule_refinement(sp_df, initial_rules, target_col='FRAUD_TRANS',
                               min_hit_rate=0.10, min_support=50,
                               refinement_steps=3):
    """
    Iteratively refine rules by adjusting thresholds to maximize hit rate.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    initial_rules : list of rule dicts
    target_col : str
    min_hit_rate : float
    min_support : int
    refinement_steps : int - Number of refinement iterations
    
    Returns:
    --------
    list of refined rules
    """
    
    print(f"\n{'='*70}")
    print("ITERATIVE RULE REFINEMENT")
    print(f"{'='*70}")
    
    pdf = sp_df.to_pandas()
    refined_rules = []
    
    for rule_idx, rule in enumerate(initial_rules[:20]):  # Refine top 20 rules
        print(f"\n  Refining Rule #{rule_idx + 1}: {rule['rule_string']}")
        
        best_rule = rule.copy()
        best_hit_rate = rule['hit_rate']
        
        for step in range(refinement_steps):
            # Try adjusting each condition's threshold
            for cond_idx, condition in enumerate(rule['conditions']):
                col = condition['variable']
                direction = condition['direction']
                current_threshold = condition['threshold']
                
                # Generate candidate thresholds around current
                if direction == '>':
                    # Try increasing threshold (tighter rule, higher hit rate)
                    candidates = np.linspace(
                        current_threshold,
                        current_threshold * 1.5 if current_threshold > 0 else current_threshold + abs(current_threshold) * 0.5 + 1,
                        10
                    )
                else:
                    # Try decreasing threshold (tighter rule, higher hit rate)
                    candidates = np.linspace(
                        current_threshold * 0.5 if current_threshold > 0 else current_threshold - abs(current_threshold) * 0.5 - 1,
                        current_threshold,
                        10
                    )
                
                for new_thresh in candidates:
                    # Build mask with modified condition
                    mask = pd.Series([True] * len(pdf), index=pdf.index)
                    new_conditions = []
                    rule_parts = []
                    
                    for ci, cond in enumerate(rule['conditions']):
                        c_col = cond['variable']
                        c_dir = cond['direction']
                        c_thresh = new_thresh if ci == cond_idx else cond['threshold']
                        
                        if c_dir == '>':
                            mask = mask & (pdf[c_col] > c_thresh)
                        else:
                            mask = mask & (pdf[c_col] < c_thresh)
                        
                        new_cond = {
                            'variable': c_col,
                            'direction': c_dir,
                            'threshold': c_thresh
                        }
                        new_conditions.append(new_cond)
                        rule_parts.append(f"{c_col} {c_dir} {c_thresh:.4f}")
                    
                    subset = pdf[mask]
                    support = len(subset)
                    
                    if support >= min_support:
                        fraud_count = subset[target_col].sum()
                        hit_rate = fraud_count / support if support > 0 else 0
                        
                        if hit_rate > best_hit_rate:
                            best_hit_rate = hit_rate
                            best_rule = {
                                'conditions': new_conditions,
                                'hit_rate': hit_rate,
                                'fraud_captured': int(fraud_count),
                                'support': int(support),
                                'n_variables': rule['n_variables'],
                                'rule_string': ' AND '.join(rule_parts),
                                'pct_fraud_captured': fraud_count / pdf[target_col].sum() if pdf[target_col].sum() > 0 else 0
                            }
        
        if best_hit_rate > rule['hit_rate']:
            print(f"    Improved: {rule['hit_rate']:.2%} -> {best_hit_rate:.2%}")
            print(f"    New Rule: {best_rule['rule_string']}")
        else:
            print(f"    No improvement found. Keeping original.")
        
        refined_rules.append(best_rule)
    
    # Sort refined rules
    refined_rules.sort(key=lambda x: (-x['hit_rate'], -x['fraud_captured']))
    
    return refined_rules


