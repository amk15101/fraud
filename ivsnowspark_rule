def generate_snowpark_implementation(rule):
    """
    Generate complete Snowpark implementation code for a rule.
    
    Parameters:
    -----------
    rule : dict - Rule dictionary
    
    Returns:
    --------
    str : Python code string
    """
    
    code_lines = []
    code_lines.append("# Snowpark Implementation for Fraud Rule")
    code_lines.append("from snowflake.snowpark import functions as F")
    code_lines.append("")
    code_lines.append("def apply_fraud_rule(sp_df):")
    code_lines.append(f'    """')
    code_lines.append(f'    Rule: {rule["rule_string"]}')
    code_lines.append(f'    Expected Hit Rate: {rule["hit_rate"]:.2%}')
    code_lines.append(f'    """')
    code_lines.append("")
    
    # Build filter condition
    filter_parts = []
    for condition in rule['conditions']:
        col = condition['variable']
        direction = condition['direction']
        threshold = condition['threshold']
        
        if direction == '>':
            filter_parts.append(f'    cond_{col.lower()} = F.col("{col}") > {threshold}')
        else:
            filter_parts.append(f'    cond_{col.lower()} = F.col("{col}") < {threshold}')
    
    code_lines.extend(filter_parts)
    code_lines.append("")
    
    # Combine conditions
    cond_vars = [f'cond_{c["variable"].lower()}' for c in rule['conditions']]
    combined = ' & '.join(cond_vars)
    code_lines.append(f'    combined_condition = {combined}')
    code_lines.append("")
    code_lines.append('    # Flag suspicious transactions')
    code_lines.append('    result_df = sp_df.with_column(')
    code_lines.append('        "FRAUD_RULE_FLAG",')
    code_lines.append('        F.when(combined_condition, F.lit(1)).otherwise(F.lit(0))')
    code_lines.append('    )')
    code_lines.append("")
    code_lines.append('    return result_df')
    
    return '\n'.join(code_lines)


def rule_overlap_analysis(sp_df, rules, target_col='FRAUD_TRANS', top_n=10):
    """
    Analyze overlap between top rules to find complementary rules
    that together capture more fraud.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    rules : list of rule dicts
    target_col : str
    top_n : int - Number of top rules to analyze
    
    Returns:
    --------
    dict with overlap analysis
    """
    
    print(f"\n{'='*70}")
    print("RULE OVERLAP ANALYSIS")
    print(f"{'='*70}")
    
    pdf = sp_df.to_pandas()
    total_fraud = pdf[target_col].sum()
    
    # Get masks for each rule
    rule_masks = []
    for rule in rules[:top_n]:
        mask = pd.Series([True] * len(pdf), index=pdf.index)
        for condition in rule['conditions']:
            col = condition['variable']
            direction = condition['direction']
            threshold = condition['threshold']
            
            if direction == '>':
                mask = mask & (pdf[col] > threshold)
            else:
                mask = mask & (pdf[col] < threshold)
        
        rule_masks.append(mask)
    
    # Find best non-overlapping rule combination
    print("\n  Finding best complementary rule combinations...")
    
    best_combo = None
    best_total_fraud_captured = 0
    best_combined_hit_rate = 0
    
    for i in range(len(rule_masks)):
        for j in range(i + 1, len(rule_masks)):
            combined_mask = rule_masks[i] | rule_masks[j]
            combined_support = combined_mask.sum()
            combined_fraud = pdf.loc[combined_mask, target_col].sum()
            combined_hit_rate = combined_fraud / combined_support if combined_support > 0 else 0
            
            if combined_fraud > best_total_fraud_captured and combined_hit_rate >= 0.10:
                best_total_fraud_captured = combined_fraud
                best_combined_hit_rate = combined_hit_rate
                best_combo = (i, j)
    
    if best_combo:
        i, j = best_combo
        print(f"\n  Best Complementary Pair:")
        print(f"    Rule A: {rules[i]['rule_string']}")
        print(f"    Rule B: {rules[j]['rule_string']}")
        print(f"    Combined Fraud Captured: {best_total_fraud_captured}")
        print(f"    Combined Hit Rate: {best_combined_hit_rate:.2%}")
        print(f"    Fraud Capture Rate: {best_total_fraud_captured / total_fraud:.2%}")
    
    # Greedy combination for maximum fraud capture
    print("\n  Greedy Rule Stacking (OR logic):")
    
    combined_mask = pd.Series([False] * len(pdf), index=pdf.index)
    selected_rules = []
    
    for idx in range(len(rule_masks)):
        new_combined = combined_mask | rule_masks[idx]
        new_support = new_combined.sum()
        new_fraud = pdf.loc[new_combined, target_col].sum()
        new_hit_rate = new_fraud / new_support if new_support > 0 else 0
        
        # Only add if hit rate stays above threshold
        if new_hit_rate >= 0.10:
            incremental_fraud = new_fraud - pdf.loc[combined_mask, target_col].sum()
            if incremental_fraud > 0:
                combined_mask = new_combined
                selected_rules.append(idx)
                print(f"    + Rule #{idx + 1}: +{int(incremental_fraud)} fraud | "
                      f"Cumulative: {int(new_fraud)} fraud | "
                      f"Hit Rate: {new_hit_rate:.2%} | "
                      f"Capture: {new_fraud / total_fraud:.2%}")
    
    final_support = combined_mask.sum()
    final_fraud = pdf.loc[combined_mask, target_col].sum()
    final_hit_rate = final_fraud / final_support if final_support > 0 else 0
    
    print(f"\n  FINAL STACKED RESULT:")
    print(f"    Rules Used: {len(selected_rules)}")
    print(f"    Total Flagged: {final_support:,}")
    print(f"    Total Fraud Captured: {int(final_fraud):,}")
    print(f"    Overall Hit Rate: {final_hit_rate:.2%}")
    print(f"    Fraud Capture Rate: {final_fraud / total_fraud:.2%}")
    
    return {
        'selected_rule_indices': selected_rules,
        'combined_hit_rate': final_hit_rate,
        'combined_fraud_captured': int(final_fraud),
        'combined_support': int(final_support),
        'fraud_capture_rate': final_fraud / total_fraud
    }


