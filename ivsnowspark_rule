def create_fraud_flag_table(sp_df, rules, target_col='FRAUD_TRANS', 
                            output_table_name='FRAUD_FLAGGED_TRANSACTIONS'):
    """
    Create a Snowflake table with fraud flags based on discovered rules.
    Applies multiple rules and creates flag columns for each.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    rules : list of rule dicts
    target_col : str
    output_table_name : str - Name of output table in Snowflake
    
    Returns:
    --------
    Snowpark DataFrame with flag columns
    """
    
    print(f"\n{'='*70}")
    print("CREATING FRAUD FLAG TABLE IN SNOWFLAKE")
    print(f"{'='*70}")
    
    result_df = sp_df
    
    for i, rule in enumerate(rules[:10], 1):  # Apply top 10 rules
        filter_condition = None
        
        for condition in rule['conditions']:
            col = condition['variable']
            direction = condition['direction']
            threshold = condition['threshold']
            
            if direction == '>':
                cond = F.col(col) > threshold
            else:
                cond = F.col(col) < threshold
            
            if filter_condition is None:
                filter_condition = cond
            else:
                filter_condition = filter_condition & cond
        
        flag_col_name = f'FRAUD_RULE_{i}_FLAG'
        result_df = result_df.with_column(
            flag_col_name,
            F.when(filter_condition, F.lit(1)).otherwise(F.lit(0))
        )
        
        print(f"  Added column: {flag_col_name} | Rule: {rule['rule_string'][:60]}...")
    
    # Create combined flag (any rule fires)
    flag_cols = [f'FRAUD_RULE_{i}_FLAG' for i in range(1, min(len(rules), 10) + 1)]
    
    if flag_cols:
        combined_expr = F.col(flag_cols[0])
        for fc in flag_cols[1:]:
            combined_expr = combined_expr + F.col(fc)
        
        result_df = result_df.with_column(
            'FRAUD_ANY_RULE_FLAG',
            F.when(combined_expr > 0, F.lit(1)).otherwise(F.lit(0))
        )
        
        result_df = result_df.with_column(
            'FRAUD_RULES_FIRED_COUNT',
            combined_expr
        )
        
        print(f"\n  Added column: FRAUD_ANY_RULE_FLAG (OR of all rules)")
        print(f"  Added column: FRAUD_RULES_FIRED_COUNT (count of rules fired)")
    
    # Write to Snowflake table
    try:
        result_df.write.mode('overwrite').save_as_table(output_table_name)
        print(f"\n  ✅ Table created: {output_table_name}")
    except Exception as e:
        print(f"\n  ⚠️ Could not save table: {e}")
        print(f"  Returning DataFrame instead.")
    
    return result_df


def sensitivity_analysis(sp_df, rule, target_col='FRAUD_TRANS', 
                         threshold_range_pct=0.20, n_steps=10):
    """
    Perform sensitivity analysis on a rule by varying thresholds.
    Shows how hit rate and fraud capture change with threshold adjustments.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    rule : dict - Rule to analyze
    target_col : str
    threshold_range_pct : float - Percentage range to vary thresholds
    n_steps : int - Number of steps in each direction
    
    Returns:
    --------
    DataFrame with sensitivity results
    """
    
    print(f"\n{'='*70}")
    print("SENSITIVITY ANALYSIS")
    print(f"{'='*70}")
    print(f"  Base Rule: {rule['rule_string']}")
    print(f"  Base Hit Rate: {rule['hit_rate']:.2%}")
    print(f"  Varying thresholds by ±{threshold_range_pct*100:.0f}%")
    
    pdf = sp_df.to_pandas()
    results = []
    
    for cond_idx, condition in enumerate(rule['conditions']):
        col = condition['variable']
        direction = condition['direction']
        base_threshold = condition['threshold']
        
        print(f"\n  Variable: {col} ({direction} {base_threshold:.4f})")
        print(f"  {'Threshold':<15} {'Hit Rate':<12} {'Fraud':<10} {'Support':<10}")
        print(f"  {'-'*47}")
        
        # Generate range of thresholds
        if base_threshold != 0:
            low = base_threshold * (1 - threshold_range_pct)
            high = base_threshold * (1 + threshold_range_pct)
        else:
            low = base_threshold - 1
            high = base_threshold + 1
        
        thresholds = np.linspace(low, high, n_steps * 2 + 1)
        
        for thresh in thresholds:
            # Apply rule with modified threshold
            mask = pd.Series([True] * len(pdf), index=pdf.index)
            
            for ci, cond in enumerate(rule['conditions']):
                c_col = cond['variable']
                c_dir = cond['direction']
                c_thresh = thresh if ci == cond_idx else cond['threshold']
                
                if c_dir == '>':
                    mask = mask & (pdf[c_col] > c_thresh)
                else:
                    mask = mask & (pdf[c_col] < c_thresh)
            
            subset = pdf[mask]
            support = len(subset)
            fraud_count = subset[target_col].sum() if support > 0 else 0
            hit_rate = fraud_count / support if support > 0 else 0
            
            marker = " <<<" if thresh == base_threshold else ""
            print(f"  {thresh:<15.4f} {hit_rate:<12.4f} {int(fraud_count):<10} {support:<10}{marker}")
            
            results.append({
                'variable': col,
                'direction': direction,
                'threshold': thresh,
                'is_base': abs(thresh - base_threshold) < 1e-10,
                'hit_rate': hit_rate,
                'fraud_captured': int(fraud_count),
                'support': support
            })
    
    return pd.DataFrame(results)


def export_rules_to_sql(rules, target_col='FRAUD_TRANS', table_name='TRANSACTIONS'):
    """
    Export rules as SQL CASE statements for direct use in Snowflake.
    
    Parameters:
    -----------
    rules : list of rule dicts
    target_col : str
    table_name : str
    
    Returns:
    --------
    str : SQL query
    """
    
    print(f"\n{'='*70}")
    print("SQL EXPORT")
    print(f"{'='*70}")
    
    sql_parts = []
    sql_parts.append(f"SELECT *,")
    
    for i, rule in enumerate(rules[:10], 1):
        case_conditions = []
        for condition in rule['conditions']:
            col = condition['variable']
            direction = condition['direction']
            threshold = condition['threshold']
            case_conditions.append(f"{col} {direction} {threshold}")
        
        where_clause = " AND ".join(case_conditions)
        sql_parts.append(f"  CASE WHEN {where_clause} THEN 1 ELSE 0 END AS FRAUD_RULE_{i},")
    
    # Combined flag
    rule_refs = [f"FRAUD_RULE_{i}" for i in range(1, min(len(rules), 10) + 1)]
    combined = " + ".join(rule_refs)
    
    sql_parts.append(f"  CASE WHEN ({combined}) > 0 THEN 1 ELSE 0 END AS FRAUD_ANY_RULE,")
    sql_parts.append(f"  ({combined}) AS FRAUD_RULES_FIRED_COUNT")
    sql_parts.append(f"FROM {table_name};")
    
    sql_query = "\n".join(sql_parts)
    
    print(sql_query)
    
    # Also generate WHERE clause for filtering
    print(f"\n\n-- Filter query for best rule:")
    if rules:
        best_conditions = []
        for condition in rules[0]['conditions']:
            col = condition['variable']
            direction = condition['direction']
            threshold = condition['threshold']
            best_conditions.append(f"{col} {direction} {threshold}")
        
        where_clause = " AND ".join(best_conditions)
        print(f"SELECT * FROM {table_name}")
        print(f"WHERE {where_clause};")
    
    return sql_query


