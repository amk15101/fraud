                        if hit_rate >= min_hit_rate:
                            rule = {
                                'rule_description': (
                                    f"{col1} = '{value1}' AND "
                                    f"{col2} = '{value2}' AND "
                                    f"{col3} = '{value3}'"
                                ),
                                'rule_columns': f"{col1} | {col2} | {col3}",
                                'rule_values': f"{value1} | {value2} | {value3}",
                                'rule_type': 'categorical',
                                'combination_depth': 3,
                                'total_records': count,
                                'fraud_count': fraud_count,
                                'hit_rate': hit_rate,
                                'fraud_amount_sum': fraud_amount,
                                'avg_fraud_amount': avg_fraud_amt,
                                'lift': hit_rate / overall_fraud_rate if overall_fraud_rate > 0 else 0,
                                'fraud_capture_rate': fraud_count / total_fraud if total_fraud > 0 else 0
                            }
                            three_var_rules.append(rule)
            except Exception:
                continue

        all_rules.extend(three_var_rules)
        print(f"  Three-variable rules found: {len(three_var_rules)}")

    # 4-variable combinations
    if max_combination_depth >= 4:
        print("\n[STEP 6] Generating four-variable combination rules...")
        single_rule_cols = set()
        for rule in all_rules:
            if rule['combination_depth'] == 1:
                single_rule_cols.add(rule['rule_columns'])

        top_columns = list(single_rule_cols)[:12]
        four_var_rules_cat = []
        col_combinations_4 = list(combinations(top_columns, 4))
        print(f"  Total 4-variable combinations to test: {len(col_combinations_4)}")

        for idx, (col1, col2, col3, col4) in enumerate(col_combinations_4):
            if (idx + 1) % 50 == 0:
                print(f"    Processing combination {idx + 1}/{len(col_combinations_4)}...")
            try:
                rule_stats = working_df.group_by(
                    F.col(col1), F.col(col2), F.col(col3), F.col(col4)
                ).agg(
                    F.count("*").alias("TOTAL_COUNT"),
                    F.sum(F.col(target_flag).cast(IntegerType())).alias("FRAUD_COUNT"),
                    F.sum(
                        F.when(F.col(target_flag) == 1, F.col(target_amt)).otherwise(F.lit(0))
                    ).alias("FRAUD_AMOUNT_SUM"),
                    F.avg(
                        F.when(F.col(target_flag) == 1, F.col(target_amt)).otherwise(F.lit(None))
                    ).alias("AVG_FRAUD_AMOUNT")
                ).filter(
                    F.col("TOTAL_COUNT") >= min_support
                ).collect()

                for row in rule_stats:
                    value1 = row[col1]
                    value2 = row[col2]
                    value3 = row[col3]
                    value4 = row[col4]
                    count = row['TOTAL_COUNT']
                    fraud_count = row['FRAUD_COUNT'] or 0
                    fraud_amount = row['FRAUD_AMOUNT_SUM'] or 0
                    avg_fraud_amt = row['AVG_FRAUD_AMOUNT'] or 0

                    if count >= min_support and count > 0:
                        hit_rate = fraud_count / count
                        if hit_rate >= min_hit_rate:
                            rule = {
                                'rule_description': (
                                    f"{col1} = '{value1}' AND "
                                    f"{col2} = '{value2}' AND "
                                    f"{col3} = '{value3}' AND "
                                    f"{col4} = '{value4}'"
                                ),
                                'rule_columns': f"{col1} | {col2} | {col3} | {col4}",
                                'rule_values': f"{value1} | {value2} | {value3} | {value4}",
                                'rule_type': 'categorical',
                                'combination_depth': 4,
                                'total_records': count,
                                'fraud_count': fraud_count,
                                'hit_rate': hit_rate,
                                'fraud_amount_sum': fraud_amount,
                                'avg_fraud_amount': avg_fraud_amt,
                                'lift': hit_rate / overall_fraud_rate if overall_fraud_rate > 0 else 0,
                                'fraud_capture_rate': fraud_count / total_fraud if total_fraud > 0 else 0
                            }
                            four_var_rules_cat.append(rule)
            except Exception:
                continue

        all_rules.extend(four_var_rules_cat)
        print(f"  Four-variable rules found: {len(four_var_rules_cat)}")

    # 5-variable combinations
    if max_combination_depth >= 5:
        print("\n[STEP 7] Generating five-variable combination rules...")
        single_rule_cols = set()
        for rule in all_rules:
            if rule['combination_depth'] == 1:
                single_rule_cols.add(rule['rule_columns'])

        top_columns = list(single_rule_cols)[:10]
        five_var_rules_cat = []
        col_combinations_5 = list(combinations(top_columns, 5))
        print(f"  Total 5-variable combinations to test: {len(col_combinations_5)}")

        for idx, (col1, col2, col3, col4, col5) in enumerate(col_combinations_5):
            if (idx + 1) % 50 == 0:
                print(f"    Processing combination {idx + 1}/{len(col_combinations_5)}...")
            try:
                rule_stats = working_df.group_by(
                    F.col(col1), F.col(col2), F.col(col3), F.col(col4), F.col(col5)
                ).agg(
                    F.count("*").alias("TOTAL_COUNT"),
                    F.sum(F.col(target_flag).cast(IntegerType())).alias("FRAUD_COUNT"),
                    F.sum(
                        F.when(F.col(target_flag) == 1, F.col(target_amt)).otherwise(F.lit(0))
                    ).alias("FRAUD_AMOUNT_SUM"),
                    F.avg(
                        F.when(F.col(target_flag) == 1, F.col(target_amt)).otherwise(F.lit(None))
                    ).alias("AVG_FRAUD_AMOUNT")
                ).filter(
                    F.col("TOTAL_COUNT") >= min_support
                ).collect()

                for row in rule_stats:
                    value1 = row[col1]
                    value2 = row[col2]
                    value3 = row[col3]
                    value4 = row[col4]
                    value5 = row[col5]
                    count = row['TOTAL_COUNT']
                    fraud_count = row['FRAUD_COUNT'] or 0
                    fraud_amount = row['FRAUD_AMOUNT_SUM'] or 0
                    avg_fraud_amt = row['AVG_FRAUD_AMOUNT'] or 0

                    if count >= min_support and count > 0:
                        hit_rate = fraud_count / count
                        if hit_rate >= min_hit_rate:
                            rule = {
                                'rule_description': (
                                    f"{col1} = '{value1}' AND "
                                    f"{col2} = '{value2}' AND "
                                    f"{col3} = '{value3}' AND "
                                    f"{col4} = '{value4}' AND "
                                    f"{col5} = '{value5}'"
                                ),
                                'rule_columns': f"{col1} | {col2} | {col3} | {col4} | {col5}",
                                'rule_values': f"{value1} | {value2} | {value3} | {value4} | {value5}",
