    print(f"CATEGORICAL RULES SUMMARY")
    print(f"{'=' * 80}")
    print(f"  Total rules generated: {len(rules_df)}")
    for d in range(1, max_combination_depth + 1):
        count = len(rules_df[rules_df['combination_depth'] == d])
        if count > 0:
            print(f"  {d}-variable rules: {count}")
    print(f"  Max hit rate: {rules_df['hit_rate'].max():.2%}")
    print(f"  Max lift: {rules_df['lift'].max():.2f}x")

    return rules_df


# =============================================================================
# FUNCTION 2: NUMERIC THRESHOLD RULES (SNOWPARK) - UP TO 8 VARIABLES
# =============================================================================

def generate_numeric_threshold_rules_snowpark(
    sp_df: DataFrame,
    target_flag: str = "FRAUD_TRANS",
    target_amt: str = "FRAUD_AMT",
    min_hit_rate: float = 0.10,
    min_support: int = 100,
    exclude_patterns: Optional[List[str]] = None,
    percentile_thresholds: List[float] = None,
    max_variable_depth: int = 8
):
    """
    Generate numeric threshold rules with up to 8 variables.
    ONLY creates rules in format:
        variable > threshold
        variable <= threshold
    NEVER creates range/between rules.
    """
    if exclude_patterns is None:
        exclude_patterns = [
            'id', 'ID', 'Id', '_id', '_ID',
            'date', 'Date', 'DATE', '_dt', '_DT',
            'time', 'Time', 'TIME', 'timestamp',
            'key', 'Key', 'KEY',
            'name', 'Name', 'NAME',
            'address', 'phone', 'email', 'ssn',
            'account_number', 'acct_no', 'card_number',
            'ip_address', 'uuid'
        ]

    if percentile_thresholds is None:
        percentile_thresholds = [0.05, 0.10, 0.25, 0.50, 0.75, 0.90, 0.95]

    print("=" * 80)
    print("NUMERIC THRESHOLD RULE GENERATION (SNOWPARK)")
    print(f"MAX VARIABLE DEPTH: {max_variable_depth}")
    print("RULE FORMAT: var > X  or  var <= X  (NO RANGES / NO BETWEEN)")
    print("=" * 80)

    total_count = sp_df.count()
    total_fraud = sp_df.filter(F.col(target_flag) == 1).count()
    overall_fraud_rate = total_fraud / total_count if total_count > 0 else 0

    print(f"  Total records: {total_count:,}")
    print(f"  Total frauds: {total_fraud:,}")
    print(f"  Overall fraud rate: {overall_fraud_rate:.4%}")

    def should_exclude(col_name: str) -> bool:
        for pattern in exclude_patterns:
            if pattern.lower() in col_name.lower():
                return True
        return False

    schema = sp_df.schema
    numeric_snowpark_types = (
        'LongType', 'IntegerType', 'FloatType', 'DoubleType', 'DecimalType'
    )
    numeric_columns = []
    for field in schema.fields:
        dtype_str = str(field.datatype)
        if any(nt in dtype_str for nt in numeric_snowpark_types):
            if field.name not in [target_flag, target_amt] and not should_exclude(field.name):
                numeric_columns.append(field.name)

    print(f"\n  Numeric columns to analyze: {len(numeric_columns)}")
    print(f"  Columns: {numeric_columns}")

    # Helpers
    def build_condition_from_description(rule_desc: str):
        parts = rule_desc.split(' AND ')
        condition = None
        for part in parts:
            part = part.strip()
            if ' > ' in part:
                col_part, val_part = part.split(' > ', 1)
                cond = F.col(col_part.strip()) > F.lit(float(val_part.strip()))
            elif ' <= ' in part:
                col_part, val_part = part.split(' <= ', 1)
                cond = F.col(col_part.strip()) <= F.lit(float(val_part.strip()))
            else:
                continue
            condition = cond if condition is None else (condition & cond)
        return condition

    def get_columns_from_description(rule_desc: str) -> set:
        parts = rule_desc.split(' AND ')
        cols = set()
        for part in parts:
            part = part.strip()
            if ' > ' in part:
                cols.add(part.split(' > ', 1)[0].strip())
            elif ' <= ' in part:
                cols.add(part.split(' <= ', 1)[0].strip())
        return cols

    def test_rule(rule_desc: str, min_obs: int = 100):
        condition = build_condition_from_description(rule_desc)
        if condition is None:
            return None
        try:
            stats = sp_df.filter(condition).agg(
                F.count("*").alias("TOTAL_COUNT"),
                F.sum(F.col(target_flag).cast(IntegerType())).alias("FRAUD_COUNT"),
                F.sum(
                    F.when(F.col(target_flag) == 1, F.col(target_amt)).otherwise(F.lit(0))
                ).alias("FRAUD_AMOUNT_SUM")
            ).collect()[0]

            count = stats['TOTAL_COUNT']
            fraud = stats['FRAUD_COUNT'] or 0
            fraud_amt = stats['FRAUD_AMOUNT_SUM'] or 0

            if count >= min_obs and count > 0:
                hit_rate = fraud / count
                if hit_rate >= min_hit_rate:
                    return {
                        'total_records': count,
                        'fraud_count': fraud,
                        'hit_rate': hit_rate,
                        'fraud_amount_sum': fraud_amt,
                        'avg_fraud_amount': fraud_amt / fraud if fraud > 0 else 0,
                        'lift': hit_rate / overall_fraud_rate if overall_fraud_rate > 0 else 0,
                        'fraud_capture_rate': fraud / total_fraud if total_fraud > 0 else 0
                    }
        except Exception:
            pass
        return None

    # Pre-compute percentiles
    print("\n  Pre-computing percentiles for all numeric columns...")
    column_percentiles = {}

    for col in numeric_columns:
        try:
            select_exprs = [
                F.call_function("APPROX_PERCENTILE", F.col(col), F.lit(pct)).alias(f"P{i}")
                for i, pct in enumerate(percentile_thresholds)
            ]
            percentile_row = sp_df.select(*select_exprs).collect()

            if percentile_row:
                row_data = percentile_row[0]
                values = []
                for i in range(len(percentile_thresholds)):
                    val = row_data[f"P{i}"]
                    values.append(float(val) if val is not None else 0.0)

                seen = set()
                unique = []
                for pct, val in zip(percentile_thresholds, values):
                    if val not in seen:
                        seen.add(val)
                        unique.append((pct, val))
                column_percentiles[col] = unique
        except Exception as e:
            print(f"    Warning: Could not get percentiles for {col}: {e}")
            continue

    print(f"  Percentiles computed for {len(column_percentiles)} columns")

    # Phase 1: 1-variable rules
    print("\n" + "-" * 60)
    print("  PHASE 1: Building 1-variable rules...")
    print("-" * 60)

    all_threshold_rules = []

    for col in numeric_columns:
        if col not in column_percentiles:
            continue
        for pct, threshold in column_percentiles[col]:
            rule_desc = f"{col} > {threshold:.4f}"
            result = test_rule(rule_desc, min_obs=min_support)
            if result:
                all_threshold_rules.append({
                    'rule_description': rule_desc,
                    'rule_columns': col,
                    'rule_type': 'greater_than',
                    'threshold_value': threshold,
                    'percentile': pct,
                    'combination_depth': 1,
                    **result
                })

            rule_desc = f"{col} <= {threshold:.4f}"
            result = test_rule(rule_desc, min_obs=min_support)
            if result:
                all_threshold_rules.append({
                    'rule_description': rule_desc,
                    'rule_columns': col,
                    'rule_type': 'less_than_equal',
                    'threshold_value': threshold,
                    'percentile': pct,
                    'combination_depth': 1,
                    **result
                })

    print(f"  1-variable rules found: {len(all_threshold_rules)}")

    # Phase 2: 2-variable rules
    two_var_rules = []
    if max_variable_depth >= 2 and all_threshold_rules:
        print("\n" + "-" * 60)
        print("  PHASE 2: Building 2-variable rules...")
        print("-" * 60)

        sorted_1var = sorted(all_threshold_rules, key=lambda x: x['hit_rate'], reverse=True)
        top_1var = sorted_1var[:15]

        for i in range(len(top_1var)):
            for j in range(i + 1, len(top_1var)):
                if top_1var[i]['rule_columns'] == top_1var[j]['rule_columns']:
                    continue
                rule_desc = f"{top_1var[i]['rule_description']} AND {top_1var[j]['rule_description']}"
                result = test_rule(rule_desc, min_obs=min_support)
                if result:
                    two_var_rules.append({
                        'rule_description': rule_desc,
                        'rule_columns': f"{top_1var[i]['rule_columns']} | {top_1var[j]['rule_columns']}",
                        'rule_type': 'multi_threshold',
                        'threshold_value': None,
                        'percentile': None,
                        'combination_depth': 2,
                        **result
                    })

        all_threshold_rules.extend(two_var_rules)
        print(f"  2-variable rules found: {len(two_var_rules)}")

    # Generic depth builder
    def build_next_depth(prev_rules, depth, top_n_seeds, top_n_single, min_obs):
        new_rules = []
        if not prev_rules:
            return new_rules
        sorted_prev = sorted(prev_rules, key=lambda x: x['hit_rate'] * x['fraud_capture_rate'], reverse=True)[:top_n_seeds]
        sorted_single = sorted(all_threshold_rules, key=lambda x: x['hit_rate'], reverse=True)
        top_single = [r for r in sorted_single if r['combination_depth'] == 1][:top_n_single]

        for combo in sorted_prev:
            used_cols = get_columns_from_description(combo['rule_description'])
            for single in top_single:
                if single['rule_columns'] in used_cols:
                    continue
                rule_desc = f"{combo['rule_description']} AND {single['rule_description']}"
                result = test_rule(rule_desc, min_obs=min_obs)
                if result:
                    all_cols = used_cols | {single['rule_columns']}
                    new_rules.append({
                        'rule_description': rule_desc,
                        'rule_columns': ' | '.join(sorted(all_cols)),
                        'rule_type': 'multi_threshold',
                        'threshold_value': None,
                        'percentile': None,
                        'combination_depth': depth,
                        **result
                    })
        return new_rules

    # Phases 3-8
    three_var_rules = []
    if max_variable_depth >= 3 and two_var_rules:
        print(f"\n  PHASE 3: Building 3-variable rules...")
        three_var_rules = build_next_depth(two_var_rules, 3, 10, 12, max(min_support // 2, 50))
        all_threshold_rules.extend(three_var_rules)
        print(f"  3-variable rules found: {len(three_var_rules)}")

    four_var_rules = []
    if max_variable_depth >= 4 and three_var_rules:
        print(f"\n  PHASE 4: Building 4-variable rules...")
        four_var_rules = build_next_depth(three_var_rules, 4, 8, 10, max(min_support // 4, 20))
        all_threshold_rules.extend(four_var_rules)
        print(f"  4-variable rules found: {len(four_var_rules)}")

    five_var_rules = []
    if max_variable_depth >= 5 and four_var_rules:
        print(f"\n  PHASE 5: Building 5-variable rules...")
        five_var_rules = build_next_depth(four_var_rules, 5, 5, 8, max(min_support // 8, 10))
        all_threshold_rules.extend(five_var_rules)
        print(f"  5-variable rules found: {len(five_var_rules)}")

    six_var_rules = []
    if max_variable_depth >= 6 and five_var_rules:
        print(f"\n  PHASE 6: Building 6-variable rules...")
        six_var_rules = build_next_depth(five_var_rules, 6, 5, 8, max(min_support // 10, 10))
        all_threshold_rules.extend(six_var_rules)
        print(f"  6-variable rules found: {len(six_var_rules)}")

    seven_var_rules = []
    if max_variable_depth >= 7 and six_var_rules:
        print(f"\n  PHASE 7: Building 7-variable rules...")
        seven_var_rules = build_next_depth(six_var_rules, 7, 4, 7, max(min_support // 12, 5))
        all_threshold_rules.extend(seven_var_rules)
        print(f"  7-variable rules found: {len(seven_var_rules)}")

    eight_var_rules = []
    if max_variable_depth >= 8 and seven_var_rules:
        print(f"\n  PHASE 8: Building 8-variable rules...")
        eight_var_rules = build_next_depth(seven_var_rules, 8, 3, 6, max(min_support // 15, 5))
        all_threshold_rules.extend(eight_var_rules)
        print(f"  8-variable rules found: {len(eight_var_rules)}")

    # Compile
    if not all_threshold_rules:
        print("\n  No threshold rules found!")
        return pd.DataFrame()

    threshold_rules_df = pd.DataFrame(all_threshold_rules)
    threshold_rules_df = threshold_rules_df.sort_values(
        by=['hit_rate', 'fraud_count'], ascending=[False, False]
    ).reset_index(drop=True)
    threshold_rules_df['rule_rank'] = range(1, len(threshold_rules_df) + 1)
    threshold_rules_df['hit_rate_pct'] = threshold_rules_df['hit_rate'].apply(lambda x: f"{x:.2%}")
    threshold_rules_df['fraud_capture_rate_pct'] = threshold_rules_df['fraud_capture_rate'].apply(lambda x: f"{x:.2%}")

    print(f"\n{'=' * 80}")
    print(f"NUMERIC THRESHOLD RULES SUMMARY")
    print(f"{'=' * 80}")
    print(f"  Total rules: {len(threshold_rules_df)}")
    for depth in range(1, 9):
        count = len(threshold_rules_df[threshold_rules_df['combination_depth'] == depth])
        if count > 0:
            print(f"  {depth}-variable rules: {count}")
    print(f"  Max hit rate: {threshold_rules_df['hit_rate'].max():.2%}")
    print(f"  Max lift: {threshold_rules_df['lift'].max():.2f}x")

    return threshold_rules_df


# =============================================================================
# FUNCTION 3: MIXED COMBINATION RULES (NUMERIC + CATEGORICAL)
# Rules like: amt > 100 AND mcc = '1771' AND trans_type = 'V' AND amt_24hr > 200
# =============================================================================

def generate_mixed_combination_rules_snowpark(
    sp_df: DataFrame,
    target_flag: str = "FRAUD_TRANS",
    target_amt: str = "FRAUD_AMT",
    min_hit_rate: float = 0.10,
    min_support: int = 100,
    exclude_patterns: Optional[List[str]] = None,
    percentile_thresholds: List[float] = None,
    max_cardinality: int = 50,
    max_mixed_depth: int = 8
):
    """
    Generate MIXED combination rules combining numeric AND categorical conditions.
    
    Examples:
        amt > 100 AND mcc = '1771'
        amt > 100 AND mcc = '1771' AND trans_type = 'V'
        amt > 100 AND mcc = '1771' AND trans_type = 'V' AND amt_24hr > 200 AND cnt_24hr > 12
    
    ONLY uses: var > X, var <= X, var = 'value'
    NEVER creates ranges/between.
    """
    if exclude_patterns is None:
        exclude_patterns = [
            'id', 'ID', 'Id', '_id', '_ID',
            'date', 'Date', 'DATE', '_dt', '_DT',
            'time', 'Time', 'TIME', 'timestamp',
            'key', 'Key', 'KEY',
            'name', 'Name', 'NAME',
            'address', 'phone', 'email', 'ssn',
            'account_number', 'acct_no', 'card_number',
            'ip_address', 'uuid'
        ]

    if percentile_thresholds is None:
        percentile_thresholds = [0.05, 0.10, 0.25, 0.50, 0.75, 0.90, 0.95]

    print("=" * 80)
    print("MIXED COMBINATION RULE GENERATION (NUMERIC + CATEGORICAL)")
    print(f"MAX DEPTH: {max_mixed_depth} variables")
    print("FORMAT: var > X AND var = 'value' AND var <= Y (NO RANGES)")
    print("=" * 80)

    total_count = sp_df.count()
    total_fraud = sp_df.filter(F.col(target_flag) == 1).count()
    overall_fraud_rate = total_fraud / total_count if total_count > 0 else 0

    print(f"  Total records: {total_count:,}")
    print(f"  Total frauds: {total_fraud:,}")
    print(f"  Overall fraud rate: {overall_fraud_rate:.4%}")

    # Identify columns
    def should_exclude(col_name: str) -> bool:
        for pattern in exclude_patterns:
            if pattern.lower() in col_name.lower():
                return True
        return False

    schema = sp_df.schema
    numeric_snowpark_types = ('LongType', 'IntegerType', 'FloatType', 'DoubleType', 'DecimalType')

    numeric_columns = []
    categorical_columns = []

    for field in schema.fields:
        if field.name in [target_flag, target_amt] or should_exclude(field.name):
            continue
        dtype_str = str(field.datatype)
        if any(nt in dtype_str for nt in numeric_snowpark_types):
            distinct_count = sp_df.select(F.col(field.name)).distinct().count()
            if distinct_count <= 10:
                categorical_columns.append(field.name)
            else:
                numeric_columns.append(field.name)
        else:
            distinct_count = sp_df.select(F.col(field.name)).distinct().count()
            if distinct_count <= max_cardinality:
                categorical_columns.append(field.name)

    print(f"\n  Numeric columns: {len(numeric_columns)} → {numeric_columns}")
    print(f"  Categorical columns: {len(categorical_columns)} → {categorical_columns}")

    # =========================================================================
    # HELPERS
    # =========================================================================
    def build_condition(rule_desc: str):
        parts = rule_desc.split(' AND ')
        condition = None
        for part in parts:
            part = part.strip()
            if ' > ' in part and " = '" not in part:
                col_part, val_part = part.split(' > ', 1)
                cond = F.col(col_part.strip()) > F.lit(float(val_part.strip()))
            elif ' <= ' in part:
                col_part, val_part = part.split(' <= ', 1)
                cond = F.col(col_part.strip()) <= F.lit(float(val_part.strip()))
            elif " = '" in part:
                col_part, val_part = part.split(" = ", 1)
                val_clean = val_part.strip().strip("'")
                cond = F.col(col_part.strip()) == F.lit(val_clean)
            elif " = " in part:
                col_part, val_part = part.split(" = ", 1)
                val_clean = val_part.strip().strip("'")
                try:
                    cond = F.col(col_part.strip()) == F.lit(float(val_clean))
                except ValueError:
                    cond = F.col(col_part.strip()) == F.lit(val_clean)
            else:
                continue
            condition = cond if condition is None else (condition & cond)
        return condition

    def get_columns_from_rule(rule_desc: str) -> set:
        parts = rule_desc.split(' AND ')
        cols = set()
        for part in parts:
            part = part.strip()
            if ' > ' in part and " = '" not in part:
                cols.add(part.split(' > ', 1)[0].strip())
            elif ' <= ' in part:
                cols.add(part.split(' <= ', 1)[0].strip())
            elif ' = ' in part:
                cols.add(part.split(' = ', 1)[0].strip())
        return cols

    def test_rule(rule_desc: str, min_obs: int = 100):
        condition = build_condition(rule_desc)
        if condition is None:
            return None
        try:
            stats = sp_df.filter(condition).agg(
                F.count("*").alias("TOTAL_COUNT"),
                F.sum(F.col(target_flag).cast(IntegerType())).alias("FRAUD_COUNT"),
                F.sum(
                    F.when(F.col(target_flag) == 1, F.col(target_amt)).otherwise(F.lit(0))
                ).alias("FRAUD_AMOUNT_SUM")
            ).collect()[0]

            count = stats['TOTAL_COUNT']
            fraud = stats['FRAUD_COUNT'] or 0
            fraud_amt = stats['FRAUD_AMOUNT_SUM'] or 0

            if count >= min_obs and count > 0:
                hit_rate = fraud / count
                if hit_rate >= min_hit_rate:
                    return {
                        'total_records': count,
                        'fraud_count': fraud,
                        'hit_rate': hit_rate,
                        'fraud_amount_sum': fraud_amt,
                        'avg_fraud_amount': fraud_amt / fraud if fraud > 0 else 0,
                        'lift': hit_rate / overall_fraud_rate if overall_fraud_rate > 0 else 0,
                        'fraud_capture_rate': fraud / total_fraud if total_fraud > 0 else 0
                    }
        except Exception:
            pass
        return None

    # =========================================================================
    # PRE-COMPUTE PERCENTILES
    # =========================================================================
    print("\n  Pre-computing percentiles...")
    column_percentiles = {}
    for col in numeric_columns:
        try:
            select_exprs = [
                F.call_function("APPROX_PERCENTILE", F.col(col), F.lit(pct)).alias(f"P{i}")
                for i, pct in enumerate(percentile_thresholds)
            ]
            row = sp_df.select(*select_exprs).collect()[0]
            values = []
            for i in range(len(percentile_thresholds)):
                val = row[f"P{i}"]
                values.append(float(val) if val is not None else 0.0)
            seen = set()
            unique = []
            for pct, val in zip(percentile_thresholds, values):
                if val not in seen:
                    seen.add(val)
                    unique.append((pct, val))
            column_percentiles[col] = unique
        except Exception:
            continue

    # =========================================================================
    # PRE-COMPUTE TOP FRAUD CATEGORIES
    # =========================================================================
    print("  Pre-computing top fraud categories...")
    column_top_categories = {}
    for col in categorical_columns:
        try:
            cat_stats = sp_df.group_by(F.col(col)).agg(
                F.count("*").alias("CNT"),
                F.sum(F.col(target_flag).cast(IntegerType())).alias("FRAUD_CNT")
            ).filter(F.col("CNT") >= max(min_support // 2, 30)).collect()

            good_cats = []
            for row in cat_stats:
                cnt = row['CNT']
                fraud_cnt = row['FRAUD_CNT'] or 0
                if cnt > 0:
                    hr = fraud_cnt / cnt
                    if hr >= min_hit_rate * 0.3:
                        good_cats.append((row[col], hr, cnt, fraud_cnt))

            good_cats.sort(key=lambda x: x[1], reverse=True)
            column_top_categories[col] = good_cats[:8]
        except Exception:
            continue

    print(f"  Percentiles for {len(column_percentiles)} numeric cols")
    print(f"  Categories for {len(column_top_categories)} categorical cols")

    # =========================================================================
    # BUILD SINGLE-CONDITION BUILDING BLOCKS
    # =========================================================================
    numeric_blocks = []
    for col in numeric_columns:
        if col not in column_percentiles:
            continue
        for pct, threshold in column_percentiles[col]:
            numeric_blocks.append({'condition': f"{col} > {threshold:.4f}", 'column': col, 'type': 'numeric'})
            numeric_blocks.append({'condition': f"{col} <= {threshold:.4f}", 'column': col, 'type': 'numeric'})

    categorical_blocks = []
    for col, categories in column_top_categories.items():
        for (value, hr, cnt, fraud_cnt) in categories:
            if value is not None:
                categorical_blocks.append({
                    'condition': f"{col} = '{value}'",
                    'column': col,
                    'type': 'categorical',
                    'base_hit_rate': hr
                })

    print(f"\n  Numeric blocks: {len(numeric_blocks)}")
    print(f"  Categorical blocks: {len(categorical_blocks)}")

    # =========================================================================
    # PHASE 1: TEST SINGLES
    # =========================================================================
    print("\n" + "-" * 60)
    print("  PHASE 1: Testing single blocks...")
    print("-" * 60)

    all_mixed_rules = []
    qualified_numeric = []
    qualified_categorical = []

    for block in numeric_blocks:
        result = test_rule(block['condition'], min_obs=min_support)
        if result:
            all_mixed_rules.append({
                'rule_description': block['condition'],
                'rule_columns': block['column'],
                'rule_type': 'mixed_combination',
                'combination_depth': 1,
                'num_numeric_conditions': 1,
                'num_categorical_conditions': 0,
                **result
            })
            qualified_numeric.append(block)

    for block in categorical_blocks:
        result = test_rule(block['condition'], min_obs=min_support)
        if result:
            all_mixed_rules.append({
                'rule_description': block['condition'],
                'rule_columns': block['column'],
                'rule_type': 'mixed_combination',
                'combination_depth': 1,
                'num_numeric_conditions': 0,
                'num_categorical_conditions': 1,
                **result
            })
            qualified_categorical.append(block)

    # Sort and limit
    qualified_numeric.sort(
        key=lambda x: next((r['hit_rate'] for r in all_mixed_rules if r['rule_description'] == x['condition']), 0),
        reverse=True
    )
    qualified_categorical.sort(key=lambda x: x.get('base_hit_rate', 0), reverse=True)

    top_numeric = qualified_numeric[:15]
    top_categorical = qualified_categorical[:10]

    print(f"  Qualified numeric: {len(qualified_numeric)} (using top {len(top_numeric)})")
    print(f"  Qualified categorical: {len(qualified_categorical)} (using top {len(top_categorical)})")

    # =========================================================================
    # PHASE 2: 2-VARIABLE MIXED RULES
    # =========================================================================
    print("\n" + "-" * 60)
    print("  PHASE 2: Building 2-variable MIXED rules...")
    print("  Example: amt > 100 AND mcc = '1771'")
    print("-" * 60)

    two_var_mixed = []

    # Numeric + Categorical
    for num_block in top_numeric:
        for cat_block in top_categorical:
            if num_block['column'] == cat_block['column']:
                continue
            rule_desc = f"{num_block['condition']} AND {cat_block['condition']}"
            result = test_rule(rule_desc, min_obs=min_support)
            if result:
                two_var_mixed.append({
                    'rule_description': rule_desc,
                    'rule_columns': f"{num_block['column']} | {cat_block['column']}",
                    'rule_type': 'mixed_combination',
                    'combination_depth': 2,
                    'num_numeric_conditions': 1,
                    'num_categorical_conditions': 1,
                    **result
                })

    # Numeric + Numeric
    for i in range(min(len(top_numeric), 10)):
        for j in range(i + 1, min(len(top_numeric), 10)):
            if top_numeric[i]['column'] == top_numeric[j]['column']:
                continue
            rule_desc = f"{top_numeric[i]['condition']} AND {top_numeric[j]['condition']}"
            result = test_rule(rule_desc, min_obs=min_support)
            if result:
                two_var_mixed.append({
                    'rule_description': rule_desc,
                    'rule_columns': f"{top_numeric[i]['column']} | {top_numeric[j]['column']}",
                    'rule_type': 'mixed_combination',
                    'combination_depth': 2,
                    'num_numeric_conditions': 2,
                    'num_categorical_conditions': 0,
                    **result
                })

    # Categorical + Categorical
    for i in range(min(len(top_categorical), 8)):
        for j in range(i + 1, min(len(top_categorical), 8)):
            if top_categorical[i]['column'] == top_categorical[j]['column']:
                continue
            rule_desc = f"{top_categorical[i]['condition']} AND {top_categorical[j]['condition']}"
            result = test_rule(rule_desc, min_obs=min_support)
            if result:
                two_var_mixed.append({
                    'rule_description': rule_desc,
                    'rule_columns': f"{top_categorical[i]['column']} | {top_categorical[j]['column']}",
                    'rule_type': 'mixed_combination',
                    'combination_depth': 2,
                    'num_numeric_conditions': 0,
                    'num_categorical_conditions': 2,
                    **result
                })

    all_mixed_rules.extend(two_var_mixed)
    print(f"  2-variable mixed rules found: {len(two_var_mixed)}")

    # =========================================================================
    # GENERIC EXTENSION FUNCTION FOR PHASES 3-8
    # =========================================================================
    def extend_rules(seed_rules, current_depth, top_n_seeds, min_obs):
        """Extend seed rules by adding one more numeric OR categorical condition."""
        new_rules = []
        if not seed_rules:
            return new_rules

        sorted_seeds = sorted(
            seed_rules,
            key=lambda x: x['hit_rate'] * x['fraud_capture_rate'],
            reverse=True
        )[:top_n_seeds]

        for seed in sorted_seeds:
            used_cols = get_columns_from_rule(seed['rule_description'])
            num_n = seed.get('num_numeric_conditions', 0)
            num_c = seed.get('num_categorical_conditions', 0)

            # Add numeric condition
            for num_block in top_numeric:
                if num_block['column'] in used_cols:
                    continue
                rule_desc = f"{seed['rule_description']} AND {num_block['condition']}"
                result = test_rule(rule_desc, min_obs=min_obs)
                if result:
                    all_cols = used_cols | {num_block['column']}
                    new_rules.append({
                        'rule_description': rule_desc,
                        'rule_columns': ' | '.join(sorted(all_cols)),
                        'rule_type': 'mixed_combination',
                        'combination_depth': current_depth,
                        'num_numeric_conditions': num_n + 1,
                        'num_categorical_conditions': num_c,
                        **result
                    })

            # Add categorical condition
            for cat_block in top_categorical:
                if cat_block['column'] in used_cols:
                    continue
                rule_desc = f"{seed['rule_description']} AND {cat_block['condition']}"
                result = test_rule(rule_desc, min_obs=min_obs)
                if result:
                    all_cols = used_cols | {cat_block['column']}
                    new_rules.append({
                        'rule_description': rule_desc,
                        'rule_columns': ' | '.join(sorted(all_cols)),
                        'rule_type': 'mixed_combination',
                        'combination_depth': current_depth,
                        'num_numeric_conditions': num_n,
                        'num_categorical_conditions': num_c + 1,
                        **result
                    })

        return new_rules

    # =========================================================================
    # PHASE 3: 3-VARIABLE MIXED RULES
    # =========================================================================
    three_var_mixed = []
    if max_mixed_depth >= 3 and two_var_mixed:
        print("\n" + "-" * 60)
        print("  PHASE 3: Building 3-variable MIXED rules...")
        print("  Example: amt > 100 AND mcc = '1771' AND trans_type = 'V'")
        print("-" * 60)

        three_var_mixed = extend_rules(
            seed_rules=two_var_mixed,
            current_depth=3,
            top_n_seeds=12,
            min_obs=max(min_support // 2, 50)
        )
        all_mixed_rules.extend(three_var_mixed)
        print(f"  3-variable mixed rules found: {len(three_var_mixed)}")
    else:
