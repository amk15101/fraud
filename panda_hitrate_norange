    df_variable_name: str = "df"
):
    """Export rules as copy-paste ready Python/Pandas conditions."""
    print("=" * 80)
    print("EXPORTING RULES AS PYTHON/PANDAS CONDITIONS")
    print("Format: var > X, var <= X, var = 'value' (NO RANGES)")
    print("=" * 80)

    top_rules = rules_df.head(top_n)
    python_conditions = []

    for idx, row in top_rules.iterrows():
        rule_desc = row['rule_description']
        rule_type = row.get('rule_type', 'categorical')
        rule_rank = row.get('final_rank', row.get('rule_rank', idx + 1))

        conditions = []
        parts = rule_desc.split(' AND ')

        for part in parts:
            part = part.strip()
            if ' > ' in part:
                col, val = part.split(' > ', 1)
                conditions.append(f"({df_variable_name}['{col.strip()}'] > {float(val.strip())})")
            elif ' <= ' in part:
                col, val = part.split(' <= ', 1)
