                except (ValueError, TypeError):
                    conditions.append(f"({df_variable_name}['{col}'] == '{val}')")

        condition_str = " & ".join(conditions)

        python_conditions.append({
            'rule_rank': rule_rank,
            'rule_description': rule_desc,
            'rule_type': rule_type,
