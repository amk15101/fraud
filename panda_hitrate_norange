def create_test_data(n_records: int = 100000, seed: int = 42) -> pd.DataFrame:
    """Create synthetic fraud data for testing."""
    np.random.seed(seed)

    df = pd.DataFrame({
        'customer_id': range(1, n_records + 1),
        'transaction_id': [f'TXN_{i:08d}' for i in range(1, n_records + 1)],
        'trans_date': pd.date_range('2024-01-01', periods=n_records, freq='min'),
        'amount': np.random.exponential(500, n_records).round(2),
        'merchant_category': np.random.choice(
            ['retail', 'grocery', 'gas', 'online', 'travel'], n_records
        ),
        'channel': np.random.choice(['POS', 'online', 'ATM', 'mobile'], n_records),
        'country': np.random.choice(
            ['US', 'US', 'US', 'US', 'UK', 'CA', 'MX'], n_records
        ),
        'num_trans_24hr': np.random.poisson(3, n_records),
        'days_since_last': np.random.exponential(10, n_records).astype(int),
        'distance_from_home': np.random.exponential(50, n_records).round(1),
        'is_weekend': np.random.choice([0, 1], n_records, p=[0.7, 0.3]),
        'hour_of_day': np.random.randint(0, 24, n_records),
        'card_age_months': np.random.randint(1, 60, n_records),
        'avg_monthly_spend': np.random.normal(2000, 800, n_records).round(0),
        'model_score': np.random.normal(400, 150, n_records).round(1),
        'velocity_score': np.random.normal(50, 20, n_records).round(1),
        'risk_score': np.random.normal(30, 15, n_records).round(1),
    })

    # Derived features
    df['ratio_to_avg'] = (df['amount'] / df['avg_monthly_spend'].clip(lower=1) * 30).round(2)

    # Generate fraud based on patterns
    fraud_prob = np.full(n_records, 0.02)
    fraud_prob += (df['amount'] > 2000) * 0.15
    fraud_prob += (df['num_trans_24hr'] > 8) * 0.20
    fraud_prob += (df['distance_from_home'] > 200) * 0.12
    fraud_prob += (df['country'] != 'US') * 0.08
    fraud_prob += ((df['channel'] == 'online') & (df['amount'] > 1000)) * 0.10
    fraud_prob += (df['hour_of_day'].isin([1, 2, 3, 4])) * 0.05
    fraud_prob += (df['ratio_to_avg'] > 5) * 0.18
    fraud_prob += (df['model_score'] > 700) * 0.25
    fraud_prob += (df['velocity_score'] > 85) * 0.10
    fraud_prob += (df['risk_score'] > 60) * 0.08
    fraud_prob = np.clip(fraud_prob, 0, 0.95)

    df['fraud_trans'] = (np.random.random(n_records) < fraud_prob).astype(int)
    df['fraud_amt'] = df['fraud_trans'] * df['amount']

    print(f"  Synthetic data created: {n_records:,} records")
    print(f"  Fraud rate: {df['fraud_trans'].mean():.4%}")
    print(f"  Fraud count: {df['fraud_trans'].sum():,}")

    return df


