# FUNCTION 5: GREEDY RULE SELECTION / OVERLAP ANALYSIS (PANDAS)
# =============================================================================

def greedy_rule_selection_pandas(
    df: pd.DataFrame,
    rules_df: pd.DataFrame,
    target_flag: str = "fraud_trans",
    top_n_rules: int = 20,
    max_selected: int = 15
):
    """
    Greedy selection of non-redundant rules that maximize fraud coverage.
    Each iteration picks the rule with highest marginal fraud gain.
    """
    print("=" * 80)
    print("GREEDY RULE SELECTION & OVERLAP ANALYSIS (PANDAS)")
    print("=" * 80)
    print("GREEDY RULE SELECTION & OVERLAP ANALYSIS (PANDAS)")
    print("=" * 80)

    total_fraud = df[target_flag].sum()
    top_rules = rules_df.head(top_n_rules)

    print(f"  Total fraud in dataset: {total_fraud:,}")
    print(f"  Candidate rules to evaluate: {len(top_rules)}")

    # Pre-compute fraud masks for each rule
    rule_fraud_masks = {}

    for idx, row in top_rules.iterrows():
        rule_rank = row.get('final_rank', row.get('rule_rank', idx + 1))
        rule_desc = row['rule_description']
        rule_type = row.get('rule_type', 'categorical')

        try:
            if rule_type == 'categorical':
                parts = rule_desc.split(' AND ')
                mask = pd.Series([True] * len(df), index=df.index)
                for part in parts:
                    part = part.strip()
                    if " = " in part:
                        col_part, val_part = part.split(" = ", 1)
                        col_part = col_part.strip()
                        val_part = val_part.strip().strip("'")
                        if val_part == 'None' or val_part == 'null':
                            mask = mask & df[col_part].isna()
                        else:
                            try:
                                numeric_val = float(val_part)
                                mask = mask & (df[col_part] == numeric_val)
                            except (ValueError, TypeError):
                                mask = mask & (df[col_part].astype(str) == val_part)

            elif rule_type in ('greater_than', 'less_than_equal', 'multi_threshold'):
                parts = rule_desc.split(' AND ')
                mask = pd.Series([True] * len(df), index=df.index)
                for part in parts:
                    part = part.strip()
                    if ' > ' in part:
                        col_part, val_part = part.split(' > ', 1)
                        mask = mask & (df[col_part.strip()] > float(val_part.strip()))
                    elif ' <= ' in part:
                        col_part, val_part = part.split(' <= ', 1)
                        mask = mask & (df[col_part.strip()] <= float(val_part.strip()))
                    elif " = " in part:
                        col_part, val_part = part.split(" = ", 1)
                        val_part = val_part.strip().strip("'")
                        mask = mask & (df[col_part.strip()].astype(str) == val_part)
            else:
                mask = pd.Series([False] * len(df), index=df.index)

            # Get fraud indices caught by this rule
            fraud_mask = mask & (df[target_flag] == 1)
            rule_fraud_masks[idx] = set(df.index[fraud_mask])

        except Exception as e:
            print(f"  Warning: Could not parse rule {rule_rank}: {e}")
            rule_fraud_masks[idx] = set()

    # Greedy selection
    print("\n  Running greedy selection...")
    optimal_rules = []
    remaining_rule_indices = list(rule_fraud_masks.keys())
    cumulative_fraud_captured = set()

    for iteration in range(min(max_selected, len(remaining_rule_indices))):
        best_rule_idx = None
        best_marginal_gain = 0

        for rule_idx in remaining_rule_indices:
            marginal_gain = len(rule_fraud_masks[rule_idx] - cumulative_fraud_captured)
            if marginal_gain > best_marginal_gain:
                best_marginal_gain = marginal_gain
                best_rule_idx = rule_idx

        if best_rule_idx is None or best_marginal_gain == 0:
            print(f"  Stopping at iteration {iteration + 1}: no more marginal gain")
            break

        cumulative_fraud_captured.update(rule_fraud_masks[best_rule_idx])
        remaining_rule_indices.remove(best_rule_idx)

        rule_row = top_rules.loc[best_rule_idx]
        rule_total_flagged = len(rule_fraud_masks[best_rule_idx])

        # Calculate hit rate for this rule
        rule_desc = rule_row['rule_description']
        rule_type = rule_row.get('rule_type', 'categorical')
        try:
            if rule_type == 'categorical':
                parts = rule_desc.split(' AND ')
                rmask = pd.Series([True] * len(df), index=df.index)
                for part in parts:
                    part = part.strip()
                    if " = " in part:
                        col_part, val_part = part.split(" = ", 1)
                        col_part = col_part.strip()
                        val_part = val_part.strip().strip("'")
                        try:
                            rmask = rmask & (df[col_part] == float(val_part))
                        except:
                            rmask = rmask & (df[col_part].astype(str) == val_part)
            else:
                parts = rule_desc.split(' AND ')
                rmask = pd.Series([True] * len(df), index=df.index)
                for part in parts:
                    part = part.strip()
                    if ' > ' in part:
                        col_part, val_part = part.split(' > ', 1)
                        rmask = rmask & (df[col_part.strip()] > float(val_part.strip()))
                    elif ' <= ' in part:
                        col_part, val_part = part.split(' <= ', 1)
                        rmask = rmask & (df[col_part.strip()] <= float(val_part.strip()))

            total_flagged_by_rule = rmask.sum()
        except:
            total_flagged_by_rule = rule_row.get('total_records', 0)

        optimal_rules.append({
            'iteration': iteration + 1,
            'rule_rank': rule_row.get('final_rank', rule_row.get('rule_rank', best_rule_idx)),
            'rule_description': rule_row['rule_description'],
            'rule_type': rule_row.get('rule_type', 'unknown'),
            'combination_depth': rule_row.get('combination_depth', 1),
            'hit_rate': rule_row['hit_rate'],
            'total_flagged': int(total_flagged_by_rule),
            'marginal_fraud_captured': best_marginal_gain,
            'cumulative_fraud_captured': len(cumulative_fraud_captured),
            'cumulative_capture_rate': len(cumulative_fraud_captured) / total_fraud if total_fraud > 0 else 0
        })

    optimal_df = pd.DataFrame(optimal_rules)

    # Print results
    print(f"\n  {'=' * 80}")
    print(f"  OPTIMAL NON-REDUNDANT RULE SET")
    print(f"  All rules: var > X, var <= X, or var = 'value' (NO RANGES)")
    print(f"  {'=' * 80}")

    for _, row in optimal_df.iterrows():
        print(f"  #{row['iteration']:2d} | +{row['marginal_fraud_captured']:>5,} fraud | "
              f"Cumulative: {row['cumulative_capture_rate']:.2%} | "
              f"Hit Rate: {row['hit_rate']:.2%} | "
              f"Vars: {row['combination_depth']} | "
              f"Type: {row['rule_type']}")
        print(f"       | {row['rule_description'][:68]}")
        print(f"  {'-' * 80}")

    if len(optimal_df) > 0:
        print(f"\n  SUMMARY:")
        print(f"  Rules selected: {len(optimal_df)}")
        print(f"  Total fraud captured: {optimal_df['cumulative_fraud_captured'].max():,} / {total_fraud:,}")
        print(f"  Capture rate: {optimal_df['cumulative_capture_rate'].max():.2%}")

    return optimal_df


