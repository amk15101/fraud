# =============================================================================
# RULE STACKING (OR LOGIC) - Find complementary rules
# =============================================================================

def rule_stacking_snowpark(sp_df, rules, target_col='FRAUD_TRANS',
                           min_combined_hit_rate=0.10, top_n=10):
    """
    Find best combination of rules using OR logic (complementary rules).
    All done in Snowflake.
    """
    
    print(f"\n{'='*70}")
    print("RULE STACKING (OR Logic - Complementary Rules)")
    print(f"{'='*70}")
    
    total_stats = sp_df.agg(
        F.count('*').alias('TOTAL'),
        F.sum(F.col(target_col)).alias('TOTAL_FRAUD')
    ).collect()[0]
    
    total_count = total_stats['TOTAL']
    total_fraud = total_stats['TOTAL_FRAUD']
    
    # Greedy stacking
    selected_rules = []
    combined_condition = None
    
    for idx, rule in enumerate(rules[:top_n]):
        # Build this rule's condition
        rule_condition = None
        for cond in rule['conditions']:
            col = cond['variable']
            direction = cond['direction']
            threshold = cond['threshold']
            
            if direction == '>':
                c = F.col(col) > threshold
            else:
                c = F.col(col) < threshold
            
            if rule_condition is None:
                rule_condition = c
            else:
                rule_condition = rule_condition & c
        
        # Test adding this rule (OR with existing)
        if combined_condition is None:
            new_combined = rule_condition
        else:
            new_combined = combined_condition | rule_condition
        
        # Evaluate
        try:
            stats = sp_df.filter(new_combined).agg(
                F.count('*').alias('SUPPORT'),
                F.sum(F.col(target_col)).alias('FRAUD')
            ).collect()[0]
            
            new_support = stats['SUPPORT'] or 0
            new_fraud = stats['FRAUD'] or 0
            new_hit_rate = new_fraud / new_support if new_support > 0 else 0
            
            # Only add if hit rate stays above threshold
            if new_hit_rate >= min_combined_hit_rate:
                prev_fraud = 0
                if combined_condition is not None:
                    prev_stats = sp_df.filter(combined_condition).agg(
                        F.sum(F.col(target_col)).alias('FRAUD')
                    ).collect()[0]
                    prev_fraud = prev_stats['FRAUD'] or 0
                
                incremental = new_fraud - prev_fraud
                
                if incremental > 0:
                    combined_condition = new_combined
                    selected_rules.append(rule)
                    
                    capture_rate = new_fraud / total_fraud if total_fraud > 0 else 0
                    
                    print(f"  + Rule #{idx+1}: +{int(incremental)} fraud | "
                          f"Total: {int(new_fraud)} | "
                          f"HR: {new_hit_rate:.2%} | "
                          f"Capture: {capture_rate:.2%}")
                    print(f"    {rule['rule_string'][:60]}")
        except Exception as e:
            print(f"  ✗ Error evaluating rule #{idx+1}: {e}")
    
    # Final stats
    if combined_condition is not None:
        final_stats = sp_df.filter(combined_condition).agg(
            F.count('*').alias('SUPPORT'),
            F.sum(F.col(target_col)).alias('FRAUD')
        ).collect()[0]
        
        final_support = final_stats['SUPPORT'] or 0
        final_fraud = final_stats['FRAUD'] or 0
        final_hit_rate = final_fraud / final_support if final_support > 0 else 0
        final_capture = final_fraud / total_fraud if total_fraud > 0 else 0
        
        print(f"\n  {'─'*50}")
        print(f"  STACKED RESULT:")
        print(f"  Rules Used:       {len(selected_rules)}")
        print(f"  Total Flagged:    {final_support:,}")
        print(f"  Total Fraud:      {int(final_fraud):,}")
        print(f"  Hit Rate:         {final_hit_rate:.2%}")
        print(f"  Fraud Capture:    {final_capture:.2%}")
    
    return {
        'selected_rules': selected_rules,
        'n_rules': len(selected_rules),
        'combined_support': final_support if combined_condition else 0,
        'combined_fraud': int(final_fraud) if combined_condition else 0,
        'combined_hit_rate': final_hit_rate if combined_condition else 0,
        'fraud_capture_rate': final_capture if combined_condition else 0
    }


