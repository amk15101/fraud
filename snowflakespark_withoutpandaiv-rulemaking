# EXPORT RULES TO SQL FILE
# =============================================================================

def export_rules_to_sql(rules, table_name='YOUR_TABLE', output_file=None):
    """
    Export rules as SQL statements.
    
    Parameters:
    -----------
    rules : list of rule dicts
    table_name : str - Source table name
    output_file : str or None - If provided, saves to file
    
    Returns:
    --------
    str : SQL query text
    """
    
    sql_lines = []
    sql_lines.append("-- ================================================")
    sql_lines.append("-- FRAUD DETECTION RULES - SQL Implementation")
    sql_lines.append(f"-- Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    sql_lines.append(f"-- Total Rules: {len(rules)}")
    sql_lines.append("-- ================================================\n")
    
    # Individual WHERE clauses
    sql_lines.append("-- INDIVIDUAL RULE QUERIES:")
    sql_lines.append("-- ========================\n")
    
    for i, rule in enumerate(rules[:20], 1):
        conditions = []
        for cond in rule['conditions']:
            conditions.append(f"{cond['variable']} {cond['direction']} {cond['threshold']}")
        where_clause = " AND ".join(conditions)
        
        sql_lines.append(f"-- Rule #{i}: HR={rule['hit_rate']:.2%}, Fraud={rule['fraud_captured']}, Support={rule['support']}")
        sql_lines.append(f"SELECT * FROM {table_name} WHERE {where_clause};\n")
    
    # Scoring query with CASE statements
    sql_lines.append("\n-- ================================================")
    sql_lines.append("-- SCORING QUERY (Flags all rules)")
    sql_lines.append("-- ================================================\n")
    sql_lines.append(f"SELECT *,")
    
    n_rules = min(len(rules), 10)
    for i, rule in enumerate(rules[:n_rules], 1):
        conditions = []
        for cond in rule['conditions']:
            conditions.append(f"{cond['variable']} {cond['direction']} {cond['threshold']}")
        where_clause = " AND ".join(conditions)
        comma = "," if i < n_rules else ""
        sql_lines.append(f"  CASE WHEN {where_clause} THEN 1 ELSE 0 END AS FRAUD_RULE_{i}{comma}")
    
    sql_lines.append(f"FROM {table_name};\n")
    
    # Combined OR query
    sql_lines.append("\n-- ================================================")
    sql_lines.append("-- COMBINED QUERY (Any rule fires)")
    sql_lines.append("-- ================================================\n")
    
    all_conditions = []
    for i, rule in enumerate(rules[:n_rules], 1):
        conditions = []
        for cond in rule['conditions']:
            conditions.append(f"{cond['variable']} {cond['direction']} {cond['threshold']}")
        all_conditions.append(f"({' AND '.join(conditions)})")
    
    combined_where = "\n    OR ".join(all_conditions)
    sql_lines.append(f"SELECT * FROM {table_name}")
    sql_lines.append(f"WHERE {combined_where};")
    
    sql_text = "\n".join(sql_lines)
    
    if output_file:
        with open(output_file, 'w') as f:
            f.write(sql_text)
        print(f"  ✅ SQL saved to: {output_file}")
    
    print(sql_text)
    return sql_text


