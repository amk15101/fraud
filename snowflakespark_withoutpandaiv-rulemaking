def classify_iv(iv):
    """Classify IV into predictive power categories."""
    if iv < 0.02:
        return "Not Predictive"
    elif iv < 0.1:
        return "Weak"
    elif iv < 0.3:
        return "Medium"
    elif iv < 0.5:
        return "Strong"
    else:
        return "Very Strong"


def calculate_woe_iv_snowpark(sp_df, col, target_col, n_bins=10):
    """
    Calculate WOE and IV using Snowpark (no pandas).
    Uses approximate percentiles computed in Snowflake.
    
    Returns:
    --------
    iv : float
    woe_table : list of dicts
    """
    
    # Get total events and non-events
    totals = sp_df.agg(
        F.sum(F.col(target_col)).alias('TOTAL_EVENTS'),
        F.sum(F.when(F.col(target_col) == 0, 1).otherwise(0)).alias('TOTAL_NON_EVENTS'),
        F.count('*').alias('TOTAL_COUNT')
    ).collect()[0]
    
    total_events = totals['TOTAL_EVENTS']
    total_non_events = totals['TOTAL_NON_EVENTS']
    total_count = totals['TOTAL_COUNT']
    
    if total_events == 0 or total_non_events == 0:
        return 0.0, []
    
    # Get percentile boundaries for binning using approx_percentile
    percentile_list = [i / n_bins for i in range(1, n_bins)]
    
    try:
        # Get bin boundaries using approx_percentile
        percentile_exprs = []
        for p in percentile_list:
            percentile_exprs.append(
                F.call_builtin('APPROX_PERCENTILE', F.col(col), F.lit(p)).alias(f'P{int(p*100)}')
            )
        
        # Alternative: use explicit percentile calculation
        boundaries_row = sp_df.select(
            *[F.call_builtin('PERCENTILE_CONT', F.lit(p)).within_group(F.col(col).asc()).alias(f'P{int(p*100)}')
              for p in percentile_list]
        ).collect()[0]
        
        boundaries = [boundaries_row[f'P{int(p*100)}'] for p in percentile_list]
        boundaries = sorted(set(boundaries))  # Remove duplicates
        
    except Exception:
        # Fallback: get min/max and create equal-width bins
        try:
            stats = sp_df.agg(
                F.min(F.col(col)).alias('MIN_VAL'),
                F.max(F.col(col)).alias('MAX_VAL')
            ).collect()[0]
            
            min_val = stats['MIN_VAL']
            max_val = stats['MAX_VAL']
            
            if min_val is None or max_val is None or min_val == max_val:
                return 0.0, []
            
            step = (max_val - min_val) / n_bins
            boundaries = [min_val + step * i for i in range(1, n_bins)]
        except Exception:
            return 0.0, []
    
    if not boundaries:
        return 0.0, []
    
    # Build CASE WHEN for bin assignment and aggregate
    woe_table = []
    iv = 0.0
    
    # Create bin conditions
    bin_conditions = []
    
    # First bin: col <= first boundary
    bin_conditions.append(('bin_0', F.col(col) <= boundaries[0]))
    
    # Middle bins
    for i in range(len(boundaries) - 1):
        bin_conditions.append((
            f'bin_{i+1}',
            (F.col(col) > boundaries[i]) & (F.col(col) <= boundaries[i+1])
        ))
    
    # Last bin: col > last boundary
    bin_conditions.append((f'bin_{len(boundaries)}', F.col(col) > boundaries[-1]))
    
    # Calculate stats for each bin using Snowpark
    for bin_name, bin_condition in bin_conditions:
        bin_stats = sp_df.filter(bin_condition).agg(
            F.count('*').alias('BIN_COUNT'),
            F.sum(F.col(target_col)).alias('BIN_EVENTS'),
            F.sum(F.when(F.col(target_col) == 0, 1).otherwise(0)).alias('BIN_NON_EVENTS')
        ).collect()[0]
        
        bin_count = bin_stats['BIN_COUNT'] or 0
        bin_events = bin_stats['BIN_EVENTS'] or 0
        bin_non_events = bin_stats['BIN_NON_EVENTS'] or 0
        
        if bin_count == 0:
            continue
        
        # Calculate WOE
        pct_events = max(bin_events / total_events, 0.0001)
        pct_non_events = max(bin_non_events / total_non_events, 0.0001)
        
        woe = np.log(pct_non_events / pct_events)
        iv_component = (pct_non_events - pct_events) * woe
        iv += iv_component
        
        event_rate = bin_events / bin_count if bin_count > 0 else 0
        
        woe_table.append({
            'bin_name': bin_name,
            'bin_count': bin_count,
            'bin_events': bin_events,
            'bin_non_events': bin_non_events,
            'event_rate': event_rate,
            'pct_events': pct_events,
            'pct_non_events': pct_non_events,
            'woe': woe,
            'iv_component': iv_component
        })
    
    return iv, woe_table


def find_optimal_cutoffs_snowpark(sp_df, col, target_col, n_thresholds=30,
                                   min_hit_rate=0.05, min_support=50):
    """
    Find optimal cutoffs using Snowpark queries (no pandas).
    Only uses > or < conditions.
    
    Returns:
    --------
    list of cutoff dicts
    """
    
    # Get total fraud count
    totals = sp_df.agg(
        F.sum(F.col(target_col)).alias('TOTAL_FRAUD'),
        F.count('*').alias('TOTAL_COUNT')
    ).collect()[0]
    
    total_fraud = totals['TOTAL_FRAUD']
    total_count = totals['TOTAL_COUNT']
    
    if total_fraud == 0:
        return []
    
    # Get percentile-based thresholds
    percentile_list = [i / (n_thresholds + 1) for i in range(1, n_thresholds + 1)]
    
    try:
        # Calculate percentiles in Snowflake
        stats = sp_df.agg(
            F.min(F.col(col)).alias('MIN_VAL'),
            F.max(F.col(col)).alias('MAX_VAL')
        ).collect()[0]
        
        min_val = stats['MIN_VAL']
        max_val = stats['MAX_VAL']
        
        if min_val is None or max_val is None or min_val == max_val:
            return []
        
        # Generate thresholds using linspace between min and max
        thresholds = np.linspace(float(min_val), float(max_val), n_thresholds + 2)[1:-1]
        thresholds = list(set(thresholds))
        thresholds.sort()
        
    except Exception as e:
        print(f"    Error getting thresholds for {col}: {e}")
        return []
    
    cutoffs = []
    
    for thresh in thresholds:
        # Test: col > threshold
        try:
            gt_stats = sp_df.filter(F.col(col) > thresh).agg(
                F.count('*').alias('SUPPORT'),
                F.sum(F.col(target_col)).alias('FRAUD_COUNT')
            ).collect()[0]
            
            gt_support = gt_stats['SUPPORT'] or 0
            gt_fraud = gt_stats['FRAUD_COUNT'] or 0
            
            if gt_support >= min_support:
                gt_hit_rate = gt_fraud / gt_support
                if gt_hit_rate >= min_hit_rate:
                    cutoffs.append({
                        'variable': col,
                        'direction': '>',
                        'threshold': float(thresh),
                        'hit_rate': float(gt_hit_rate),
                        'fraud_captured': int(gt_fraud),
                        'support': int(gt_support),
                        'pct_fraud_captured': float(gt_fraud / total_fraud) if total_fraud > 0 else 0
                    })
        except Exception:
            pass
        
        # Test: col < threshold
        try:
            lt_stats = sp_df.filter(F.col(col) < thresh).agg(
                F.count('*').alias('SUPPORT'),
                F.sum(F.col(target_col)).alias('FRAUD_COUNT')
            ).collect()[0]
            
            lt_support = lt_stats['SUPPORT'] or 0
            lt_fraud = lt_stats['FRAUD_COUNT'] or 0
            
            if lt_support >= min_support:
                lt_hit_rate = lt_fraud / lt_support
                if lt_hit_rate >= min_hit_rate:
                    cutoffs.append({
                        'variable': col,
                        'direction': '<',
                        'threshold': float(thresh),
                        'hit_rate': float(lt_hit_rate),
                        'fraud_captured': int(lt_fraud),
                        'support': int(lt_support),
                        'pct_fraud_captured': float(lt_fraud / total_fraud) if total_fraud > 0 else 0
                    })
        except Exception:
            pass
    
    # Keep Pareto-optimal cutoffs
    final_cutoffs = get_pareto_optimal_cutoffs_v2(cutoffs, max_return=5)
    return final_cutoffs


def get_pareto_optimal_cutoffs_v2(cutoffs, max_return=5):
    """Return best cutoffs balancing hit_rate and fraud_captured."""
    if not cutoffs:
        return []
    
    pareto = []
    seen = set()
    
    # Best by hit rate
    sorted_by_hr = sorted(cutoffs, key=lambda x: -x['hit_rate'])
    for c in sorted_by_hr[:max_return]:
        key = (c['variable'], c['direction'], round(c['threshold'], 4))
        if key not in seen:
            seen.add(key)
            pareto.append(c)
    
    # Best by fraud captured
    sorted_by_fc = sorted(cutoffs, key=lambda x: -x['fraud_captured'])
    for c in sorted_by_fc[:max_return]:
        key = (c['variable'], c['direction'], round(c['threshold'], 4))
        if key not in seen:
            seen.add(key)
            pareto.append(c)
    
    # Best balanced (hit_rate * pct_fraud_captured)
    for c in cutoffs:
        c['score'] = c['hit_rate'] * c.get('pct_fraud_captured', 0)
    sorted_by_score = sorted(cutoffs, key=lambda x: -x.get('score', 0))
    for c in sorted_by_score[:max_return]:
        key = (c['variable'], c['direction'], round(c['threshold'], 4))
        if key not in seen:
            seen.add(key)
            pareto.append(c)
    
    return pareto[:max_return * 2]


def evaluate_combination_snowpark(sp_df, conditions, target_col, min_support=50):
    """
    Evaluate a combination of conditions on Snowpark DataFrame.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    conditions : list of condition dicts
    target_col : str
    min_support : int
    
    Returns:
    --------
    dict or None
    """
    
    # Build filter
    filter_condition = None
    rule_parts = []
    
    for cond in conditions:
        col = cond['variable']
        direction = cond['direction']
        threshold = cond['threshold']
        
        if direction == '>':
            c = F.col(col) > threshold
        else:
            c = F.col(col) < threshold
        
        if filter_condition is None:
            filter_condition = c
        else:
            filter_condition = filter_condition & c
        
        rule_parts.append(f"{col} {direction} {threshold:.4f}")
    
    # Evaluate
    try:
        stats = sp_df.filter(filter_condition).agg(
            F.count('*').alias('SUPPORT'),
            F.sum(F.col(target_col)).alias('FRAUD_COUNT')
        ).collect()[0]
        
        support = stats['SUPPORT'] or 0
        fraud_count = stats['FRAUD_COUNT'] or 0
        
        if support >= min_support and support > 0:
            hit_rate = fraud_count / support
            return {
                'conditions': conditions,
                'hit_rate': float(hit_rate),
                'fraud_captured': int(fraud_count),
                'support': int(support),
                'rule_string': ' AND '.join(rule_parts)
            }
    except Exception:
        pass
    
    return None


def generate_snowpark_filter(rule):
    """Generate Snowpark filter expression string."""
    filter_parts = []
    for condition in rule['conditions']:
        col = condition['variable']
        direction = condition['direction']
        threshold = condition['threshold']
        if direction == '>':
            filter_parts.append(f'(F.col("{col}") > {threshold})')
        else:
            filter_parts.append(f'(F.col("{col}") < {threshold})')
    return f"sp_df.filter({' & '.join(filter_parts)})"


