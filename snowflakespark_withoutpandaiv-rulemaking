def fraud_rule_miner(sp_df, target_col='FRAUD_TRANS', min_hit_rate=0.10,
                     max_variables=4, min_iv=0.02, n_bins=10,
                     min_rule_support=50, n_thresholds=30,
                     max_vars_for_combo=8, max_combinations=3000,
                     output_csv_path='fraud_rules_output'):
    """
    Mines fraud detection rules from Snowpark DataFrame.
    PURE SNOWPARK - Does NOT convert to Pandas. All computations in Snowflake.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
        Input dataframe with features and target
    target_col : str
        Target column name (1=fraud, 0=non-fraud)
    min_hit_rate : float
        Minimum hit rate (precision) for rules (default 10%)
    max_variables : int
        Maximum number of variables in a rule combination
    min_iv : float
        Minimum Information Value to consider a variable useful
    n_bins : int
        Number of bins for WOE calculation
    min_rule_support : int
        Minimum number of records a rule must capture
    n_thresholds : int
        Number of threshold candidates to test per variable
    max_vars_for_combo : int
        Max variables to use in combinations
    max_combinations : int
        Max combinations to test (safety limit)
    output_csv_path : str
        Directory to save CSV output files
        
    Returns:
    --------
    dict with:
        - 'rules': List of discovered rules
        - 'iv_table': IV summary
        - 'best_rule': Best rule meeting hit rate
        - 'saved_files': Paths to CSV files
    """
    
    print("=" * 70)
    print("FRAUD RULE MINER - PURE SNOWPARK (NO PANDAS)")
    print("=" * 70)
    print(f"\n  Target Column:    {target_col}")
    print(f"  Min Hit Rate:     {min_hit_rate:.0%}")
    print(f"  Max Variables:    {max_variables}")
    print(f"  Min IV:           {min_iv}")
    print(f"  N Bins (WOE):     {n_bins}")
    print(f"  Min Support:      {min_rule_support}")
    print(f"  N Thresholds:     {n_thresholds}")
    print(f"  Output CSV Path:  {output_csv_path}")
    
    # =========================================================================
    # STEP 0: Get basic stats
    # =========================================================================
    print(f"\n{'='*70}")
    print("STEP 0: DATASET OVERVIEW")
    print(f"{'='*70}")
    
    total_stats = sp_df.agg(
        F.count('*').alias('TOTAL_COUNT'),
        F.sum(F.col(target_col)).alias('TOTAL_FRAUD'),
        F.sum(F.when(F.col(target_col) == 0, 1).otherwise(0)).alias('TOTAL_NON_FRAUD')
    ).collect()[0]
    
    total_count = total_stats['TOTAL_COUNT']
    total_fraud = total_stats['TOTAL_FRAUD']
    total_non_fraud = total_stats['TOTAL_NON_FRAUD']
    fraud_rate = total_fraud / total_count if total_count > 0 else 0
    
    print(f"\n  Total Records:  {total_count:,}")
    print(f"  Total Fraud:    {total_fraud:,}")
    print(f"  Total Non-Fraud:{total_non_fraud:,}")
    print(f"  Fraud Rate:     {fraud_rate:.4%}")
    
    # Get numeric columns from schema
    numeric_types = ['DecimalType', 'DoubleType', 'FloatType', 'IntegerType', 
                     'LongType', 'ShortType', 'ByteType']
    
    schema = sp_df.schema
    numeric_cols = []
    for field in schema.fields:
        type_name = type(field.datatype).__name__
        if type_name in numeric_types and field.name != target_col:
            numeric_cols.append(field.name)
    
    print(f"\n  Numeric Features: {len(numeric_cols)}")
    print(f"  Features: {numeric_cols}")
    
    # =========================================================================
    # STEP 1: Calculate IV for each variable (in Snowflake)
    # =========================================================================
    print(f"\n{'='*70}")
    print("STEP 1: WOE & IV CALCULATION (In Snowflake)")
    print(f"{'='*70}")
    
    iv_results = {}
    woe_details = {}
    
    for i, col in enumerate(numeric_cols, 1):
        print(f"\n  [{i}/{len(numeric_cols)}] Processing: {col}...", end=" ")
        try:
            iv, woe_table = calculate_woe_iv_snowpark(sp_df, col, target_col, n_bins=n_bins)
            iv_results[col] = iv
            woe_details[col] = woe_table
            print(f"IV = {iv:.4f} ({classify_iv(iv)})")
        except Exception as e:
            print(f"FAILED: {e}")
            iv_results[col] = 0.0
    
    # Create IV summary
    iv_data = [{'Variable': k, 'IV': v, 'Predictive_Power': classify_iv(v)} 
               for k, v in sorted(iv_results.items(), key=lambda x: -x[1])]
    iv_table = pd.DataFrame(iv_data)
    
    print(f"\n\n{'─'*50}")
    print("IV SUMMARY (Sorted by IV descending):")
    print(f"{'─'*50}")
    print(iv_table.to_string(index=False))
    
    # Select useful variables
    useful_vars = [row['Variable'] for row in iv_data if row['IV'] >= min_iv]
    if not useful_vars:
        print(f"\n  ⚠️ No variables with IV >= {min_iv}. Using top {max_vars_for_combo}.")
        useful_vars = [row['Variable'] for row in iv_data[:max_vars_for_combo]]
    else:
        useful_vars = useful_vars[:max_vars_for_combo]
    
    print(f"\n  Selected {len(useful_vars)} variables for rule mining:")
    for v in useful_vars:
        print(f"    - {v} (IV={iv_results[v]:.4f})")
    
    # =========================================================================
    # STEP 2: Find optimal cutoffs per variable (in Snowflake)
    # =========================================================================
    print(f"\n{'='*70}")
    print("STEP 2: FINDING OPTIMAL CUTOFFS (In Snowflake)")
    print(f"{'='*70}")
    
    all_cutoff_rules = []
    cutoffs_by_var = {}
    
    for i, col in enumerate(useful_vars, 1):
        print(f"\n  [{i}/{len(useful_vars)}] Finding cutoffs for: {col}")
        
        try:
            cutoffs = find_optimal_cutoffs_snowpark(
                sp_df, col, target_col,
                n_thresholds=n_thresholds,
                min_hit_rate=min_hit_rate * 0.3,  # Relaxed for individual
                min_support=min_rule_support
            )
            
            if cutoffs:
                cutoffs_by_var[col] = cutoffs
                all_cutoff_rules.extend(cutoffs)
                
                for c in cutoffs:
                    print(f"    ✓ {col} {c['direction']} {c['threshold']:.4f} | "
                          f"HR: {c['hit_rate']:.2%} | "
                          f"Fraud: {c['fraud_captured']} | "
                          f"Support: {c['support']}")
            else:
                print(f"    ✗ No qualifying cutoffs found")
                
        except Exception as e:
            print(f"    ✗ Error: {e}")
    
    print(f"\n  Total cutoffs found: {len(all_cutoff_rules)}")
    print(f"  Variables with cutoffs: {len(cutoffs_by_var)}")
    
    # =========================================================================
    # STEP 3: Single variable rules
    # =========================================================================
    print(f"\n{'='*70}")
    print("STEP 3: SINGLE VARIABLE RULES")
    print(f"{'='*70}")
    
    single_var_rules = []
    
    for cutoff in all_cutoff_rules:
        if cutoff['hit_rate'] >= min_hit_rate:
            rule = {
                'conditions': [cutoff],
                'hit_rate': cutoff['hit_rate'],
                'fraud_captured': cutoff['fraud_captured'],
                'support': cutoff['support'],
                'n_variables': 1,
                'rule_string': f"{cutoff['variable']} {cutoff['direction']} {cutoff['threshold']:.4f}",
                'pct_fraud_captured': cutoff.get('pct_fraud_captured', 0)
            }
            single_var_rules.append(rule)
            print(f"  ✅ {rule['rule_string']} | HR: {rule['hit_rate']:.2%} | "
                  f"Fraud: {rule['fraud_captured']} | Support: {rule['support']}")
    
    print(f"\n  Single-variable rules meeting {min_hit_rate:.0%}: {len(single_var_rules)}")
    
    # =========================================================================
    # STEP 4: Multi-variable combination rules (in Snowflake)
    # =========================================================================
    print(f"\n{'='*70}")
    print("STEP 4: MULTI-VARIABLE COMBINATIONS (In Snowflake)")
    print(f"{'='*70}")
    
    multi_var_rules = []
    vars_with_cutoffs = list(cutoffs_by_var.keys())
    
    for n_vars in range(2, min(max_variables + 1, len(vars_with_cutoffs) + 1)):
        print(f"\n  --- {n_vars}-variable combinations ---")
        
        var_combos = list(combinations(vars_with_cutoffs, n_vars))
        
        # Limit combinations
        if len(var_combos) > 50:
            print(f"    Too many variable combos ({len(var_combos)}). Taking top 50.")
            var_combos = var_combos[:50]
        
        rules_found = 0
        combo_count = 0
        
        for var_combo in var_combos:
            # Get cutoffs for each variable (top 2 per variable)
            cutoff_lists = [sorted(cutoffs_by_var[v], key=lambda x: -x['hit_rate'])[:2] 
                          for v in var_combo]
            
            # Generate all cutoff combinations
            for combo in product(*cutoff_lists):
                combo_count += 1
                
                if combo_count > max_combinations:
                    print(f"    ⚠️ Hit max combinations limit ({max_combinations}). Stopping.")
                    break
                
                # Evaluate this combination in Snowflake
                conditions = list(combo)
                result = evaluate_combination_snowpark(
                    sp_df, conditions, target_col, min_support=min_rule_support
                )
                
                if result and result['hit_rate'] >= min_hit_rate * 0.8:
                    result['n_variables'] = n_vars
                    result['pct_fraud_captured'] = result['fraud_captured'] / total_fraud if total_fraud > 0 else 0
                    multi_var_rules.append(result)
                    rules_found += 1
                    
                    if result['hit_rate'] >= min_hit_rate:
                        print(f"    ✅ {result['rule_string']} | "
                              f"HR: {result['hit_rate']:.2%} | "
                              f"Fraud: {result['fraud_captured']}")
            
            if combo_count > max_combinations:
                break
        
        print(f"    Rules found: {rules_found} (tested {combo_count} combinations)")
        
        # Early stop if enough good rules
        if rules_found > 30:
            print(f"    Sufficient rules found. Stopping at {n_vars} variables.")
            break
    
    # =========================================================================
    # STEP 5: Compile and rank all rules
    # =========================================================================
    print(f"\n{'='*70}")
    print("STEP 5: FINAL RULE RANKING")
    print(f"{'='*70}")
    
    all_rules = single_var_rules + multi_var_rules
    all_rules.sort(key=lambda x: (-x['hit_rate'], -x['fraud_captured']))
    
    # Filter rules meeting minimum hit rate
    qualifying_rules = [r for r in all_rules if r['hit_rate'] >= min_hit_rate]
    
