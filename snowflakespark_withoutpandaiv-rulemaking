# QUICK START - SIMPLEST USAGE
# =============================================================================

def quick_start(sp_df, target_col='FRAUD_TRANS', min_hit_rate=0.10,
                output_csv_path='fraud_rules_output'):
    """
    Simplest way to run fraud rule miner.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    target_col : str - Target (1=fraud, 0=non-fraud)
    min_hit_rate : float - Minimum hit rate (default 10%)
    output_csv_path : str - Where to save CSV files
    
    Returns:
    --------
    dict with results, rules saved to CSV automatically
    """
    
    # Run main miner
    results = fraud_rule_miner(
        sp_df=sp_df,
        target_col=target_col,
        min_hit_rate=min_hit_rate,
        max_variables=4,
        min_iv=0.02,
        n_bins=10,
        min_rule_support=50,
        n_thresholds=30,
        max_vars_for_combo=8,
        max_combinations=3000,
        output_csv_path=output_csv_path
    )
    
    # Evaluate best rule
    if results.get('best_rule'):
        eval_result = evaluate_rule_on_snowpark(sp_df, results['best_rule'], target_col)
        results['evaluation'] = eval_result
    
    # Try rule stacking
    if results.get('rules') and len(results['rules']) >= 2:
        stacking = rule_stacking_snowpark(
            sp_df, results['rules'], target_col,
            min_combined_hit_rate=min_hit_rate
        )
        results['stacking'] = stacking
    
    # Print final output
    print(f"\n{'*'*70}")
    print("QUICK START RESULTS:")
    print(f"{'*'*70}")
    
    if results.get('best_rule'):
        br = results['best_rule']
        print(f"\n  Best Rule:    {br['rule_string']}")
        print(f"  Hit Rate:     {br['hit_rate']:.2%}")
        print(f"  Fraud:        {br['fraud_captured']}")
        print(f"  Support:      {br['support']}")
        
        # SQL WHERE
        sql_parts = []
        for cond in br['conditions']:
            sql_parts.append(f"{cond['variable']} {cond['direction']} {cond['threshold']}")
        print(f"\n  SQL WHERE:    {' AND '.join(sql_parts)}")
        
        # Snowpark filter
        print(f"  Snowpark:     {generate_snowpark_filter(br)}")
    
    if results.get('saved_files'):
        print(f"\n  CSV Files Saved:")
        for key, path in results['saved_files'].items():
            print(f"    📄 {key}: {path}")
    
    print(f"\n{'*'*70}\n")
    
    return results


