# =============================================================================
# RULE EVALUATION ON SNOWPARK
# =============================================================================

def evaluate_rule_on_snowpark(sp_df, rule, target_col='FRAUD_TRANS'):
    """
    Evaluate a rule on Snowpark DataFrame and print metrics.
    """
    
    # Build filter
    filter_condition = None
    for condition in rule['conditions']:
        col = condition['variable']
        direction = condition['direction']
        threshold = condition['threshold']
        
        if direction == '>':
            cond = F.col(col) > threshold
        else:
            cond = F.col(col) < threshold
        
        if filter_condition is None:
            filter_condition = cond
        else:
            filter_condition = filter_condition & cond
    
    # Total stats
    total_stats = sp_df.agg(
        F.count('*').alias('TOTAL_COUNT'),
        F.sum(F.col(target_col)).alias('TOTAL_FRAUD')
    ).collect()[0]
    
    total_count = total_stats['TOTAL_COUNT']
    total_fraud = total_stats['TOTAL_FRAUD']
    
    # Rule stats
    rule_stats = sp_df.filter(filter_condition).agg(
        F.count('*').alias('RULE_COUNT'),
        F.sum(F.col(target_col)).alias('RULE_FRAUD')
    ).collect()[0]
    
    rule_count = rule_stats['RULE_COUNT'] or 0
    rule_fraud = rule_stats['RULE_FRAUD'] or 0
    
    hit_rate = rule_fraud / rule_count if rule_count > 0 else 0
    fraud_capture = rule_fraud / total_fraud if total_fraud > 0 else 0
    fp_count = rule_count - rule_fraud
    fp_rate = fp_count / (total_count - total_fraud) if (total_count - total_fraud) > 0 else 0
    
    print(f"\n{'='*70}")
    print("RULE EVALUATION")
    print(f"{'='*70}")
    print(f"  Rule:              {rule['rule_string']}")
    print(f"  Total Records:     {total_count:,}")
    print(f"  Total Fraud:       {total_fraud:,}")
    print(f"  Rule Flagged:      {rule_count:,}")
    print(f"  Rule Fraud (TP):   {rule_fraud:,}")
    print(f"  Hit Rate:          {hit_rate:.2%}")
    print(f"  Fraud Capture:     {fraud_capture:.2%}")
    print(f"  False Positives:   {fp_count:,}")
    print(f"  FP Rate:           {fp_rate:.4%}")
    
    return {
        'rule_string': rule['rule_string'],
        'total_count': total_count,
        'total_fraud': total_fraud,
        'rule_flagged': rule_count,
        'rule_fraud': rule_fraud,
        'hit_rate': hit_rate,
        'fraud_capture_rate': fraud_capture,
        'false_positives': fp_count,
        'fp_rate': fp_rate
    }


# =============================================================================
# APPLY RULE AND FLAG RECORDS
# =============================================================================

def apply_fraud_rules(sp_df, rules, target_col='FRAUD_TRANS'):
    """
    Apply discovered rules to Snowpark DataFrame and add flag columns.
    
    Parameters:
    -----------
    sp_df : Snowpark DataFrame
    rules : list of rule dicts
    target_col : str
    
    Returns:
    --------
    Snowpark DataFrame with flag columns added
    """
    
    print(f"\n{'='*70}")
    print("APPLYING FRAUD RULES TO DATAFRAME")
    print(f"{'='*70}")
    
    result_df = sp_df
    
    for i, rule in enumerate(rules[:10], 1):
        filter_condition = None
        
        for condition in rule['conditions']:
            col = condition['variable']
            direction = condition['direction']
            threshold = condition['threshold']
            
            if direction == '>':
                cond = F.col(col) > threshold
            else:
                cond = F.col(col) < threshold
            
            if filter_condition is None:
                filter_condition = cond
            else:
                filter_condition = filter_condition & cond
        
        flag_col = f'FRAUD_RULE_{i}'
        result_df = result_df.with_column(
            flag_col,
            F.when(filter_condition, F.lit(1)).otherwise(F.lit(0))
        )
        print(f"  Added: {flag_col} | {rule['rule_string'][:50]}...")
    
    # Combined flags
    n_rules = min(len(rules), 10)
    if n_rules > 0:
        sum_expr = F.col('FRAUD_RULE_1')
        for i in range(2, n_rules + 1):
            sum_expr = sum_expr + F.col(f'FRAUD_RULE_{i}')
        
        result_df = result_df.with_column(
            'FRAUD_ANY_RULE',
            F.when(sum_expr > 0, F.lit(1)).otherwise(F.lit(0))
        )
        result_df = result_df.with_column(
            'FRAUD_RULES_COUNT',
            sum_expr
        )
        print(f"\n  Added: FRAUD_ANY_RULE (any rule fires)")
        print(f"  Added: FRAUD_RULES_COUNT (number of rules fired)")
    
    return result_df


