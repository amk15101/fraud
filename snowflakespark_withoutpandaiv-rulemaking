    # =========================================================================
    # STEP 6: Print best rule and Snowpark expression
    # =========================================================================
    print(f"\n{'='*70}")
    print("BEST RULE")
    print(f"{'='*70}")
    
    if best_rule:
        print(f"\n  Rule:           {best_rule['rule_string']}")
        print(f"  Hit Rate:       {best_rule['hit_rate']:.2%}")
        print(f"  Fraud Captured: {best_rule['fraud_captured']}")
        print(f"  Support:        {best_rule['support']}")
        print(f"  Variables:      {best_rule.get('n_variables', 'N/A')}")
        print(f"  Fraud Capture%: {best_rule.get('pct_fraud_captured', 0):.2%}")
        
        print(f"\n  Snowpark Filter:")
        print(f"  {generate_snowpark_filter(best_rule)}")
        
        # SQL WHERE clause
